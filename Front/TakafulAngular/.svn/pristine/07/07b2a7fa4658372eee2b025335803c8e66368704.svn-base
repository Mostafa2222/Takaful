import { Injectable } from '@angular/core';
import { BehaviorSubject } from 'rxjs';

@Injectable({
  providedIn: 'root',
})
export class DataSharingService {
  private dataSubject = new BehaviorSubject<any>(''); // Holds data
  sharedData$ = this.dataSubject.asObservable(); // Observable to listen for data updates

  sendData(data: any) {
    this.dataSubject.next(data);
  }
}
