.section-modal h3 {background-image: -moz-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);background-image: -webkit-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);background-image: -ms-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);margin: 0 0 5px 0;padding: 8px 10px;color: #fff;font-size: 13px;}
.table>thead>tr>td,.table>thead>tr>th {line-height: 12px;padding: 5px 3px;font-size: 10px;font-weight: 400;}
.row-inline-editable input,.row-inline-editable label,.row-inline-editable select,.row-inline-editable .chosen-container, .row-inline-editable div.form-inline{display: none;}
.row-inline-editable.active input,.row-inline-editable.active label,.row-inline-editable.active select,.row-inline-editable.active div.form-inline { display: inline;}
.row-inline-editable.active div.form-inline{display: inline-flex;}
.row-inline-editable.active .chosen-container {display: inline-block;}
.row-inline-editable.active .chosen-container span {display: inline;}
.row-inline-editable.active span {display: none;}
.row-inline-editable.active {background-color: inherit !important;}
.row-inline-editable span.editable {display: inline;}
.row-inline-editable.active span {display: block;}
.editable.label {font-weight: 500;font-size: inherit;}
.row-inline-editable.active span.editable,.row-inline-editable span ,.row-inline-editable.active br.editable{display: none;}
.fa-check-double.active,.fa-check,.fa-check-double.active,.fa-check {color: green;}
.fa-times,.fa-times {color: #c0d5e8;}
/*************************************************** Inline Adding ****************************************/
.new-row,.new-row .glyphicon-trash,.new-row.active .glyphicon-plus-sign {display: none;}
.row-inline-adding {display: none;}
.main .row-inline-adding
/*, .new-row .glyphicon-trash */
{display: inline;}
.new-row.active {display: table-row;}
.table>tbody>tr.new-row.active>td {background-color: inherit !important;}
/******************************************/
.radio-inline input[type="radio"] {margin-top: -2px;}
/************ Select2 *************/
table .select2-container {margin-bottom: 0;}
.select2-container {margin-bottom: 7px;}
.select2-container--default .select2-selection--single .select2-selection__rendered {line-height: 20px;font-size: 11px;}
.select2-container--default .select2-selection--single .select2-selection__rendered i {font-size: 19px;line-height: 20px;}
.select2-container--default .select2-selection--single .select2-selection__arrow {height: 23px;}
.select2-container .select2-selection--multiple {height: 20px;line-height: 20px;min-height: 20px;padding: 1px 0;}
.select2-container--default .select2-selection--single {background-color: #fff;border: 1px solid #ccc;border-radius: 0;}
.select2-container .select2-selection--single {box-sizing: border-box;cursor: pointer;display: block;height: 20px;user-select: none;-webkit-user-select: none;}
.select2-container--default .select2-selection--multiple .select2-selection__choice {background-color: #f5f4f4;border: 1px solid #aaaaaa45;border-radius: 0;margin-right: 4px;margin-top: 0px;padding: 0 2px;font-size: 11px;line-height: 15px;}
.select2-container--default.select2-container--focus .select2-selection--multiple {border: solid #ccc 1px;}
.select2-container--default .select2-selection--multiple {border: 1px solid #ccc;border-radius: 1px;}
/* *********************************************************************************************** */
tr.shown .details-control .fa-plus::before {content: "\f068";}
.tableChild.pre-scrollable {max-height: 250px;}
/******************************************************Backgrounds*************************************/
.i-active i {color: #337ab7 !important;}
/**********************************************************************************************************/
.col-text {overflow: hidden;text-overflow: ellipsis;white-space: nowrap;max-width: 0;}
.borderBottom {border-bottom: 2px solid #c3c2c2;}
.lightBg {background: unset;}
/* ******************************************** datatable ****************************************** */
table tbody tr.selected,table.dataTable tbody tr.selected {background-color: #B0BED9;color: #333;}
table thead tr .selected th,table.dataTable thead tr.selected {background-color: unset;color: unset;}
a.btn {color: #fff !important;}
table.dataTable tbody tr.selected a,table.dataTable tbody th.selected a,table.dataTable tbody td.selected a {color: #337ab7;}
/* ------------------------------------- upload file----------------------------------- */ .uploadFileBlock {display: none;}
.uploadBlock {padding-left: 0;padding-bottom: 0;}
.uploadBlock .input-group input[type=file] {font-size: 11px;border: none;margin: 0;}
.uploadBlock .input-group {display: flex;border: 1px solid #d8d1d1;padding: 0;margin: 0 2px 5px;float: left;}
.control-label {font-size: 11px !important;color: #296dac;}
/*  */
.w100 {width: 100% !important;}.w95 {width: 95% !important;}.w90 {width: 90% !important;}.w85 {width: 85% !important;}.w80 {width: 80% !important;}.w75 {width: 75% !important;}.w70 {width: 70% !important;}.w65 {width: 65% !important;}.w60 {width: 60% !important;}.w50 {width: 50% !important;}.w55 {width: 55% !important;}.w45 {width: 45% !important;}.w40 {width: 40% !important;}
.w35 {width: 35% !important;}.w30 {width: 30% !important;}.w25 {width: 25% !important;}.w20 {width: 20% !important;}
/*  */
.select2-results__option i {    font-size: 20px;}
.select2-icon span>i {font-size: 20px;}
.small-text{font-size: 85%;}
td .inactive {cursor: pointer !important;}
/**************************************************************************/
.section-modal h3 {background-image: -moz-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);background-image: -webkit-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);background-image: -ms-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);margin: 0 0 5px 0;padding: 8px 10px;color: #fff;font-size: 13px;}
/**************************************************************************************************/
.table>thead>tr>td,.table>thead>tr>th {line-height: 12px;padding: 10px 3px;font-size: 10px;font-weight: 400;}
/***************************************** accordion *******************************************/
.panel-heading [data-toggle="collapse"]:before {float: left !important;content: "\f068";margin-right: 6px;margin-top: 3px;font-family: "Font Awesome 5 Free"; font-weight: 900;font-size: 11px; }
.panel-heading [data-toggle="collapse"].collapsed:before {float: left !important;content: "\f067";}
.panel-heading [aria-expanded="true"].collapsed:before {content: "\f068" !important;}
.panel-title>a:hover,.panel-title>a:active,.panel-title>a:focus {text-decoration: none;}
.panel-group .panel {border-radius: 0;padding: 0;border: none;}
.panel-default>.panel-heading {color: #296dac;background-color: #d2e1ee;border-color: #ABBFD1;border-radius: 0;padding: 4px 0;}
.panel-title {font-size: 13px;color: #297cc8;}
.panel-title>a {display: block;padding: 4px 5px;text-decoration: none;}
.panel-default>.panel-heading+.panel-collapse>.panel-body {background-color: #FFF;border: 1px solid #d2e1ee;padding: 5px;margin-top: 5px;}
.panel-body .table-nobg>thead>tr>th {border-bottom: 1px solid #c8c0c0 !important;}
/* 5 col bootstrap */
.col-xs-5ths,.col-sm-5ths,.col-md-5ths,.col-lg-5ths {position: relative;min-height: 1px;padding-right: 15px;padding-left: 15px;}
.col-xs-5ths {width: 20%;float: left;}