<div id="pause" class="d-flex align-items-center justify-content-center" *ngIf="loading">
    <!-- <div id="spinner"></div> -->
    <span class="loader"></span>
</div>
<div class="light-blue">
    <div class="row">
        <div class="col-4" style="display: flex;justify-content: space-between; flex-direction: column; gap: 1rem;">
            <div>
                <label class="form-label">{{ "Organization.Timeline.Department_Definition.Organization_Template"
                    | translate}}</label>
                <select class="form-select" [(ngModel)]="selectedValue" (change)="template(selectedValue)">
                    <option value="0">{{ "Organization.Timeline.Department_Definition.Select_Criteria" |
                        translate}}</option>
                    <option value="1">{{ "Organization.Timeline.Department_Definition.Template1" | translate}}
                    </option>
                    <option value="2">{{ "Organization.Timeline.Department_Definition.Template2" | translate}}
                    </option>
                    <option value="3">{{ "Organization.Timeline.Department_Definition.Template3" | translate}}
                    </option>
                    <option value="4">{{ "Organization.Timeline.Department_Definition.Template4" | translate}}
                    </option>
                </select>
            </div>
            <div style="display: flex;gap: 1rem;">
                <div>
                    <button class="btn btn-primary btn-sm" (click)="showNames()">
                        <i class="fas fa-download me-2"></i>
                        {{ "Organization.Timeline.Department_Definition.Load_Template" | translate}}
                    </button>
                </div>
                <div>
                    <button class="btn btn-primary btn-sm" (click)="saveDept()">
                        <i class="fas fa-save me-2"></i>
                        {{ "Organization.Timeline.Department_Definition.Save" | translate}}
                    </button>
                </div>
            </div>
        </div>
        <div class="col-4">
            <label class="form-label">{{ "Organization.Timeline.Department_Definition.Select_Company" |
                translate}}</label>
            <select class="form-select" [(ngModel)]="selectedCompanyId">
                <option value="0" selected>{{ "Organization.Timeline.Department_Definition.Select_Company" | translate}}
                </option>
                <option *ngFor="let company of companies" [value]="company.id">
                    {{ translate.currentLang === 'ar' ? company.arabicName : company.latinName }}
                </option>
            </select>
        </div>
    </div>
</div>
<div class="tab-pane fade  active show" id="depDef-step" role="tabpanel">
    <div class="row">
        <div class="row ">
            <div class="col-sm-4">
                <h3>{{ "Organization.Timeline.Department_Definition.Title" | translate}}</h3>
                <div class="row">
                    <div class="col-sm-12" style="overflow-y: auto;max-height: 25rem;">
                        <div id="jqxWidget">
                            <div id="jqxTree" style="margin-top: 10px; width: 100%">
                                <p-tree [id]="'tree-' + translate.currentLang" [value]="nodes"
                                    styleClass="p-0 w-full md:w-[30rem]" [ngClass]="'tree-' + translate.currentLang"
                                    selectionMode="single" [(selection)]="selectedNode"
                                    (onNodeSelect)="nodeSelect($event)" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-8">
                <div class="inputTemplateDetails">
                    <div class="row ">
                        <div class="col-md-12">
                            <h3> {{ "Organization.Timeline.Department_Definition.Job_Details" | translate}}</h3>
                        </div>
                        <div class="col-md-12">
                            <div class="table-container">
                                <div class="table-responsive">
                                    <table class="table KeyShareholders-table table-hover table-sm">
                                        <colgroup>
                                            <col style="width: 100px;">
                                            <col>
                                            <col>
                                        </colgroup>
                                        <thead>
                                            <tr>
                                                <th>{{ "Organization.Timeline.Department_Definition.Code" | translate }}
                                                </th>
                                                <th>{{ "Organization.Timeline.Department_Definition.DescriptionEn" |
                                                    translate }}</th>
                                                <th>{{ "Organization.Timeline.Department_Definition.DescriptionAr" |
                                                    translate }}</th>
                                            </tr>
                                        </thead>
                                    </table>
                                </div>
                                <div class="table-scroll">
                                    <table class="table KeyShareholders-table table-hover table-sm">
                                        <tbody>
                                            <tr *ngFor="let job of jobDefinitions">
                                                <td>{{ job.jobCode }}</td>
                                                <td>{{ job.latinName }}</td>
                                                <td>{{ job.arabicName }}</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>