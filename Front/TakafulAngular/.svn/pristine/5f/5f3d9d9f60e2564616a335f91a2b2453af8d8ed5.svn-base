@font-face {
  font-family: 'pos-font';
  src:  url('pos-font.eot?aw6ms5');
  src:  url('pos-font.eot?aw6ms5#iefix') format('embedded-opentype'),
    url('pos-font.ttf?aw6ms5') format('truetype'),
    url('pos-font.woff?aw6ms5') format('woff'),
    url('pos-font.svg?aw6ms5#pos-font') format('svg');
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

[class^="pos-icon-"], [class*=" pos-icon-"] {
  /* use !important to prevent issues with browser extensions that change fonts */
  font-family: 'pos-font' !important;
  speak: never;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;

  /* Better Font Rendering =========== */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

