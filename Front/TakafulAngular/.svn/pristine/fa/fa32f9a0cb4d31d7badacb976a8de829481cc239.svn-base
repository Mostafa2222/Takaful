
@font-face {
  font-family: 'time-font';
  src:  url('time-font.eot?eh4337');
  src:  url('time-font.eot?eh4337#iefix') format('embedded-opentype'),
    url('time-font.ttf?eh4337') format('truetype'),
    url('time-font.woff?eh4337') format('woff'),
    url('time-font.svg?eh4337#time-font') format('svg');
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

[class^="attend-icon-"],
[class*=" attend-icon-"] {
  /* use !important to prevent issues with browser extensions that change fonts */
  font-family: 'time-font' !important;
  speak: never;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;

  /* Better Font Rendering =========== */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

