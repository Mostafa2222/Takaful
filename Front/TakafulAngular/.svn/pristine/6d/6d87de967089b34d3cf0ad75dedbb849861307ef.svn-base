import { HttpInterceptor, HttpRequest, HttpHandler, HttpEvent, HttpResponse } from "@angular/common/http";
import { Injectable } from "@angular/core";
import { Observable, throwError } from "rxjs";
import { tap, catchError, map } from "rxjs/operators";
import { Router } from "@angular/router";
import { LoaderService } from "../../helper/Services/loader.service";
import { ToastrService } from "ngx-toastr";
import { UserAuthenticationsService } from "./user-authentications.service";
import { EncryptionService } from "./encryption.service";
import { jwtDecode } from "jwt-decode";
import { CookieService } from "ngx-cookie-service";
import { DataExtractionService } from "../common Services/DataExtraction.service";

@Injectable()
export class AuthInterceptor implements HttpInterceptor {
  decryptedEmployeeId :any;
  employeeId :any;
  constructor(private router: Router, private toaster: ToastrService,
    private loaderService: LoaderService,
    /*private _auth:UserAuthenticationsService,*/
    private dataExtractionService: DataExtractionService,
    private _encryptionService: EncryptionService,
    private cookieService: CookieService) {
    debugger;
  }

  intercept(req: HttpRequest<any>, next: HttpHandler): Observable<HttpEvent<any>> {
    this.loaderService.setLoading(true, req.url);


    if (localStorage.getItem('token')) {
      const encryptedToken = this.cookieService.get('employeeId')
     // const encryptedToken = localStorage.getItem('employeeId')
      const token = localStorage.getItem('token');
      const tokenInfo = this.getDecodedAccessToken(token)
      this.employeeId = this.dataExtractionService.extractData(tokenInfo.sub).employeeId[1]
      this.decryptedEmployeeId = this._encryptionService.decrypt(encryptedToken);
      if(this.employeeId === this.decryptedEmployeeId){
        req = req.clone({
          setHeaders: {
            Authorization: `Bearer ${localStorage.getItem('token')}`
          }
        });
       }
       else{
        localStorage.clear()
        this.router.navigateByUrl('/Login');
       }

    }


    return next.handle(req).pipe(
      map((evt: any) => {
        if (evt instanceof HttpResponse) {
          this.loaderService.setLoading(false, req.url);
        }
        return evt;
      }),
      catchError((err) => {
        this.loaderService.setLoading(false, req.url);

        if (err.status === 419) {
          this.toaster.info('Session Timeout', 'warning');
          localStorage.clear()
          //localStorage.removeItem('token');
          this.router.navigateByUrl('/Login');
          localStorage.setItem("SessionTimeOut", "1");
        } else if (err.status === 401) {
          //this.toaster.info('You Are Not Authorized', 'warning');
          this.toaster.info('Session Timeout', 'warning');
          localStorage.clear()
          //localStorage.removeItem('token');
          this.router.navigateByUrl('/Login');
          localStorage.setItem("SessionTimeOut", "1");
        } else if (err.status === 400) {
          // Handle other status codes if needed
        } else {
          // Handle other status codes if needed
        }

        return throwError(err);
      })
    );
  }

   getDecodedAccessToken(token: string | any): any {
    try {
      return jwtDecode(token);
    } catch (Error) {
      return null;
    }
  }
}
