/************************* Search Sider *************************/
.search {
    text-align: center;
    position: fixed;
    top: 80px;
    left: 0px;
    right: 0px;
    z-index: 10;
    margin: 0px 15px 0px 275px;
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
}

.search.max-width {
    margin: 0px 15px 0px 60px;
}

.content.max-w .search {
    margin: 0px 30px 0px 60px;
}

.searchSlider {
    display: none;
    text-align: left;
    border: 1px solid #c3dced;
    background-color: #f0f9ff;
    overflow: auto;
    max-height: 290px;
}

.searchSlider .relatedModule {
    background-color: #d8eaf7;
    padding: 15px 15px 7px 15px;
}

.searchSlider .commonSearch {
    padding: 8px 15px 15px 15px;
}

.searchBtn {
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
}

.search-popup {
    position: relative;
}

.search-popup input {
    padding: 0px 23px 0px 3px !important;
}

.search-popup a {
    position: absolute;
    top: 0px;
    right: 0px;
    width: 20px;
    height: 20px;
    border: 1px solid #26537f;
    color: #fff;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background: -webkit-gradient(linear, left top, left bottom, from(#4ca8ff), to(#2672ba));
    background: linear-gradient(to bottom, #4ca8ff 0%, #2672ba 100%);
    -webkit-box-sizing: border-box;
    box-sizing: border-box;
    text-align: center;
    padding-top: 2px;
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
}

.panel .search-popup a {
    line-height: 16px;
    display: inline-block;
    background: #4CA6FE;
    background: -webkit-gradient(linear, left top, left bottom, from(#4CA6FE), color-stop(63%, #2666A3), to(#2673BC));
    background: linear-gradient(to bottom, #4CA6FE 0%, #2666A3 63%, #2673BC 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#4CA6FE', endColorstr='#2673BC', GradientType=0);
}

.search-popup a:hover,
.search-popup a:focus {
    color: #fff;
    background: -webkit-gradient(linear, left top, left bottom, from(#fed364), to(#fdae0e));
    background: linear-gradient(to bottom, #fed364 0%, #fdae0e 100%);
    border: 1px solid #eaa10d;
}

.btn.btn-danger {
    background: #d9534f;
    background: -webkit-gradient(linear, left top, left bottom, from(#d9534f), color-stop(63%, #d43f3a), to(#a30e24));
    background: linear-gradient(to bottom, #d9534f 0%, #d43f3a 63%, #a30e24 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#d9534f', endColorstr='#a30e24', GradientType=0);
    border: 1px solid #a30e24;
}

.btn.btn-primary {
    background: #4ca6fe;
    background: -webkit-gradient(linear, left top, left bottom, from(#4ca6fe), color-stop(63%, #2666a3), to(#2673bc));
    background: linear-gradient(to bottom, #4ca6fe 0%, #2666a3 63%, #2673bc 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#4ca6fe', endColorstr='#2673bc', GradientType=0);
    border: 1px solid #2673bc;
    color: #fff;
    font-size: 12px;
    line-height: 20px;
    border-radius: 0px;
    padding: 0px 10px;
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
    overflow: hidden;
}

.btn.btn-orange {
    color: #333;
    background: #fed364;
    background: -webkit-gradient(linear, left top, left bottom, from(#fed364), to(#fdae0e));
    background: linear-gradient(to bottom, #fed364 0%, #fdae0e 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#fed364', endColorstr='#fdae0e', GradientType=0);
    border: 1px solid #FDAE0E;
    font-size: 12px;
    line-height: 19px;
    border-radius: 0px;
    padding: 0px 10px;
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
    overflow: hidden;
}

.btn.btn-secondary {
    color: #000;
    font-size: 11px;
    line-height: 15px;
    border-radius: 0px;
    padding: 1px 9px;
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
    overflow: hidden;
    border: 1px rgb(197, 195, 195) solid;
    margin-bottom: 6px;
    background-image: -moz-linear-gradient(90deg, rgb(165, 165, 165) 0%, rgb(228, 228, 228) 100%);
    background-image: -webkit-linear-gradient(90deg, rgb(165, 165, 165) 0%, rgb(228, 228, 228) 100%);
    background-image: -ms-linear-gradient(90deg, rgb(165, 165, 165) 0%, rgb(228, 228, 228) 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#a5a5a5', endColorstr='#e4e4e4', GradientType=0);
}

.btn.btn-orange:hover {
    background: #4ca6fe;
    background: -webkit-gradient(linear, left top, left bottom, from(#4ca6fe), color-stop(63%, #2666a3), to(#2673bc));
    background: linear-gradient(to bottom, #4ca6fe 0%, #2666a3 63%, #2673bc 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#4ca6fe', endColorstr='#2673bc', GradientType=0);
    border: 1px solid #2673bc;
    color: #fff;
}

.btn.btn-danger:hover,
.btn.btn-danger:focus,
.btn.btn-primary:hover,
.btn.btn-primary:focus,
.btn.btn-secondary:hover,
.btn.btn-secondary:focus {
    color: #333;
    background: #fed364;
    background: -webkit-gradient(linear, left top, left bottom, from(#fed364), to(#fdae0e));
    background: linear-gradient(to bottom, #fed364 0%, #fdae0e 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#fed364', endColorstr='#fdae0e', GradientType=0);
    border: 1px solid #FDAE0E;
}

.modal-title {
    font-size: 15px;
    color: #296dac;
}

.search-popup .btn.btn-primary {
    padding: 0px
}

.addBtn,
.delBtn {
    width: 18px;
    border-radius: 100% !important;
    cursor: pointer;
    padding: 0px !important;
    margin-left: 5px;
    line-height: 18px !important;
}

.btn.square-icon {
    padding: 1px 2px;
    line-height: 10px;
    font-size: 10px;
}

/***************************************************** Chart of Account *****************************************************/

.ch-container {
    width: 100%;
    padding: 10px 10px 15px 10px;
    border-radius: 0px;
    background-color: #fbfdfe;
    margin: 0px auto 15px;
    border: 1px solid #c3dced;
    background: #f0f9ff;
    overflow-x: auto;
}

.ch-head {
    font-size: 12px;
    color: #333;
    margin-bottom: 5px;
}

.ch-head.row {
    margin: 0px;
}

.ch-head span {
    font-family: Tahoma;
}

.ch-head span:nth-child(2) {
    text-decoration: underline;
}

.jstree {
    margin-top: 10px;
}

.jstree-node,
.jstree-children,
.jstree-container-ul {
    display: block;
    margin: 0;
    padding: 0;
    list-style-type: none;
    list-style-image: none;
}

.jstree-default>.jstree-container-ul>.jstree-node {
    margin-left: 0;
    margin-right: 0;
}

.jstree-default .jstree-last {
    background: transparent;
}

/***************************************************** Kendo Style Overwrite *****************************************************/

.k-grid {
    border-radius: 0px;
    margin-left: 15px !important;
    margin-right: 15px !important;
    margin-top: 0px !important;
    max-width: 100%;
    line-height: 1.42857143 !important;
    height: auto !important
}

.k-grid-pager,
.k-scheduler-footer,
.k-grid-header:first-child th.k-header:first-child,
.k-rtl thead.k-grid-header th.k-header:last-child,
thead.k-grid-header th.k-header:first-child,
.k-grid-header:first-child,
.k-grid-toolbar:first-child,
.k-grid>.k-grouping-header,
.k-scheduler>.k-scheduler-toolbar:first-child {
    border-radius: 0px !important;
    padding-right: 0px !important;
}

.k-block,
.k-button,
.k-draghandle,
.k-grid-header,
.k-grouping-header,
.k-header,
.k-pager-wrap,
.k-toolbar,
.k-treemap-tile,
html .km-pane-wrapper .k-header {
    background-color: transparent;
}

.k-gantt-toolbar .k-state-default,
.k-grid .k-grouping-header,
.k-grid-header,
.k-grid-header-wrap,
.k-grouping-header .k-group-indicator,
.k-header,
.k-pager-wrap,
.k-pager-wrap .k-textbox {
    border-color: #ddd !important;
}

.k-grid thead tr:hover {
    background: transparent;
}

.k-grid-header {
    border-color: #ddd;
    background: #26537e;
    background: -webkit-gradient(linear, left top, left bottom, from(#26537e), to(#1a3a59));
    background: linear-gradient(to bottom, #26537e 0%, #1a3a59 100%);
    filter: progid: DXImageTransform.Microsoft.gradient(startColorstr='#26537e', endColorstr='#1a3a59', GradientType=0);
    color: #fff;
    text-transform: capitalize;
}

.k-filter-row th,
.k-grid-header th.k-header {
    padding: 8px;
}

.k-grid-header .k-link:link {
    color: #fff;
    text-align: center;
    text-transform: capitalize;
    font-weight: 100;
    font-size: 12px;
}

.k-grid tr td {
    border-style: solid;
    border-color: #ddd;
}

.k-grid td {
    padding: 2px 8px;
    line-height: 1.42857143;
    font-size: 12px;
    text-align: center;
}

.k-alt,
.k-pivot-layout>tbody>tr:first-child>td:first-child,
.k-resource.k-alt,
.k-separator {
    background-color: #e0f3ff;
}

.k-grid tr:hover {
    background-color: #c0e2f7;
}

.k-alt:hover,
.k-pivot-layout>tbody>tr:first-child>td:first-child:hover,
.k-resource.k-alt:hover,
.k-separator:hover {
    background-color: #e0f3ff;
}

.k-grid-content,
.k-grid-content-locked,
.k-pager-wrap {
    height: auto !important;
    overflow: auto;
}

.k-pager-wrap {
    background: #26537e;
    line-height: 1.42857143;
}

.k-pager-info {
    color: #fff;
}

.k-pager-wrap .k-link {
    border-color: #26537e !important;
    border-style: none;
    border-width: 0px;
}

.k-pager-numbers .k-link,
.k-pager-numbers .k-state-selected,
.k-pager-wrap>.k-link {
    min-width: auto;
    line-height: 1.42857143;
}

.k-pager-numbers .k-state-selected {
    border-style: none;
    border-width: 0px;
}

.k-grid-pager .k-link,
.k-grid-pager .k-link:link {
    background-color: #26537e;
    border-color: #26537e;
    color: #fff;
    padding: 0px 5px 1px;
    margin: 0px 3px;
    display: inline-block;
    -webkit-transition: all ease 0.3s;
    transition: all ease 0.3s;
}

.k-draghandle.k-state-selected:hover,
.k-ghost-splitbar-horizontal,
.k-ghost-splitbar-vertical,
.k-list>.k-state-highlight,
.k-list>.k-state-selected,
.k-marquee-color,
.k-panel>.k-state-selected,
.k-scheduler .k-scheduler-toolbar .k-state-selected,
.k-scheduler .k-today.k-state-selected,
.k-state-selected,
.k-state-selected:link,
.k-state-selected:visited {
    background-color: #fff;
    color: #23527c;
}

/*****************************************************  Orders  *****************************************************/

#ordersTabel .pre-scrollable {
    max-height: 250px;
}

.dataTables_scrollHeadInner .table {
    margin-bottom: 0;
}

.dataTables_length {
    float: right;
    position: absolute;
    bottom: 86px;
    right: 20px;
}

.dataTables_scrollHeadInner,
.dataTables_scrollHeadInner .dataTable {
    width: 100% !important;
}

.dataTables_length label {
    font-family: Verdana;
    font-size: 10px;
    margin-bottom: 0;
}

.dataTables_length select,
.cu-table select {
    margin-bottom: 0;
}

.dataTables_filter input[type="search"] {
    margin-bottom: 0;
    border: 1px solid #ccc;
}

.dataTables_info {
    text-align: center;
    margin-bottom: 5px;
    display: block;
    margin-top: 12px;
    font-size: 12px;
    color: #2d2e2f;
}

.dataTables_paginate {
    background: linear-gradient(to bottom, #26537e 0%, #1a3a59 100%);
    text-align: center !important;
}

a.paginate_button {
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    vertical-align: middle;
    text-align: center;
    display: inline-block;
    margin: 5px;
    background-color: #7dbfe5;
    border-radius: 3px;
    color: #00385b;
    font-family: Verdana;
    font-size: 10px;
    line-height: 18px;
    cursor: pointer;
}

a.current,
a.paginate_button:hover {
    background-color: #fff;
}

a.current {
    cursor: text;
}

input.button,
a.button,
button.bttn {
    background: linear-gradient(to bottom, #4ca6fe 0%, #2666a3 63%, #2673bc 100%, #2673bc 100%);
    height: 20px;
    padding: 0 15px;
    border: 1px solid #26537f;
    color: #fff;
    font-size: 11px !important;
    line-height: 18px;
    font-weight: normal;
    display: inline-block;
    position: relative;
    cursor: pointer;
    text-align: center;
}

.dataTables_length label,
.dataTables_filter label {
    width: inherit !important;
}

.higlighted td {
    background-color: #6ebdda !important;
}

.sorting {
    /* background: url(../images/sort_both.png) no-repeat; */
    background-position: center right;
}

.sorting_desc {
    /* background: url(../images/sort_desc.png) no-repeat; */
    background-position: center right;
}

.sorting_asc {
    /* background: url(../images/sort_asc.png) no-repeat; */
    background-position: center right;
}

table.dataTable tbody tr.selected {
    background-color: #B0BED9;
}