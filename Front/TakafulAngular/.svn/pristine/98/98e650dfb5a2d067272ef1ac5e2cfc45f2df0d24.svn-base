  z-index: 100000000;
  max-width: 20rem !important;
}

.legend-status {
  display: flex;
  flex-wrap: wrap;
  gap: 5px 10px;
  font-size: 11px;
  color: #555;
}

.legend-status::before {
  content: "\f0b0";
