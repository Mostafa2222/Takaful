  display: flex;
  direction: inherit;
}

.mx-center {
  margin-right: 43%;
  margin-left: 43%;
}

.calc-btn-ar {

  position: relative !important;
  left: -54px !important;
}

.p-tooltip {
  position: absolute;
  display: none;
