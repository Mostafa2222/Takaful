/*  */
.select2-results__option i {
  font-size: 20px;
}

.select2-icon span > i {
  font-size: 20px;
}

.small-text {
  font-size: 85%;
}

td .inactive {
  cursor: pointer !important;
}

/**************************************************************************/
.section-modal h3 {
  background-image: -moz-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);
  background-image: -webkit-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);
  background-image: -ms-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);
  margin: 0 0 5px 0;
  padding: 8px 10px;
  color: #fff;
  font-size: 13px;
}

/**************************************************************************************************/
.table > thead > tr > td, .table > thead > tr > th {
  line-height: 12px;
  padding: 10px 3px;
  font-size: 10px;
  font-weight: 400;
}

/***************************************** accordion *******************************************/
.panel-heading [data-toggle="collapse"]:before {
  float: left !important;
  content: "\f068";
  margin-right: 6px;
  margin-top: 3px;
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 11px;
}

.panel-heading [data-toggle="collapse"].collapsed:before {
  float: left !important;
  content: "\f067";
}

.panel-heading [aria-expanded="true"].collapsed:before {
  content: "\f068" !important;
}

.panel-title > a:hover, .panel-title > a:active, .panel-title > a:focus {
  text-decoration: none;
}

.panel-group .panel {
  border-radius: 0;
  padding: 0;
  border: none;
}

.panel-default > .panel-heading {
  color: #296dac;
  background-color: #d2e1ee;
  border-color: #ABBFD1;
  border-radius: 0;
  padding: 4px 0;
}

.panel-title {
  font-size: 13px;
  color: #297cc8;
}

.panel-title > a {
  display: block;
  padding: 4px 5px;
  text-decoration: none;
}

.panel-default > .panel-heading + .panel-collapse > .panel-body {
  background-color: #FFF;
  border: 1px solid #d2e1ee;
  padding: 5px;
  margin-top: 5px;
}

.panel-body .table-nobg > thead > tr > th {
  border-bottom: 1px solid #c8c0c0 !important;
}

/* 5 col bootstrap */
.col-xs-5ths, .col-sm-5ths, .col-md-5ths, .col-lg-5ths {
  position: relative;
  min-height: 1px;
  padding-right: 15px;
  padding-left: 15px;
}

.col-xs-5ths {
  width: 20%;
  float: left;
}

@media (min-width: 768px) {
  .col-sm-5ths {
    width: 20%;
    float: left;
  }
}

@media (min-width: 992px) {
  .col-md-5ths {
    width: 20%;
    float: left;
  }
}

@media (min-width: 1200px) {
  .col-lg-5ths {
    width: 20%;
    float: left;
  }
}

/* board */
.board-layout {
  display: grid;
  grid-template-rows: max-content auto;
  grid-gap: 10px;
  padding: 10px;
}

.list-layout {
  display: grid;
  grid-gap: 10px;
}

.board-lists {
  display: grid; /*! grid-auto-columns: 275px; */
  grid-auto-flow: column;
  grid-gap: 10px;
  height: 400px;
}

.board-list {
  background-color: rgb(222, 236, 250);
  border-radius: 3px;
  display: grid;
  grid-auto-rows: max-content;
  grid-gap: 10px; /* Chrome use a fixed height */
  height: max-content;
  padding: 10px;
  grid-auto-columns: 255px;
}

.list-title {
  font-size: 12px;
  font-weight: bold;
  color: #377bbb;
}

.list-card {
  background-color: white;
  border-radius: 3px;
  box-shadow: 0 1px 0 rgba(9, 30, 66, .25);
  padding: 0;
  cursor: pointer;
}

.list-card-title {
  font-weight: 700; /*! color: #4178e1; */
  padding: 5px 10px 3px;
}

.card-desc {
  margin: 0 10px;
  line-height: 17px;
}

/* .card-sender{} .card-equipment{} .card-department{} */
.card-desc i {
  border-radius: 100%;
  text-align: center;
  margin-bottom: 5px;
  color: #858383;
}

.card-info {
  margin: 0px 10px 5px;
}

.card-date {
  font-size: 11px;
  text-align: left;
  color: #858383;
}

.card-reapair img {
  border-radius: 100%;
  width: 35px;
  border: 1px solid #94969c;
  height: 35px;
}

.list-card ul {
  margin: 0 10px 5px;
}

.list-card ul li {
  line-height: 17px;
}

.list-img {
  margin: 0 2px;
}

.list-img img {
  border-radius: 100%;
  width: 40px;
  border: 1px solid #94969c;
  height: 40px;
}

.priority-status {
  height: 6px;
  background: #fffcfc;
  border-radius: 0 0 3px 3px;
}

.high {
  background: #c23531;
}

.low {
  background: #0da551;
}

.normal {
  background: #f8c400;
}

/*  */
.text-red {
  color: red;
}

.block-section {
  border: 1px solid #d2e1ee;
  padding: 5px 15px 9px;
  margin: 4px 0 10px 0;
}

.filter-box {
  padding: 10px 15px;
  max-height: 400px;
  background: #fff;
  position: absolute;
  top: 0px;
  display: none;
  right: 0;
  text-align: left;
  border: 1px solid #abc5de;
  box-shadow: 0px 0px 6px rgba(72, 69, 69, 0.43);
  z-index: 999;
  left: 4px;
}

#groupBy.filter-box {
  right: 10px;
}

/* board */
.form-title {
  background: #d2e1ee;
  color: #297cc8 !important;
  padding: 6px 15px;
  font-size: 14px;
  margin-bottom: 3px;
  position: relative;
}

/*  */
.pb-0 {
  padding-bottom: 0;
}

legend.scheduler-border {
  font-size: 13px;
}

.dataTables_info { /*! text-align: left; */
  font-size: 10px;
}

.t-add {
  font-size: 15px;
}

.postponed-date {
  color: #fe5353;
  text-align: right;
  padding: 5px 10px 2px 0;
  position: relative;
}

.postponed-date::before {
  content: "\f3e5";
  position: absolute;
  right: 83px;
  top: 1px;
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 12px;
  color: #fe5353;
  rotate: -94deg;
}

.form-title .side-collaps {
  position: absolute;
  left: -17px;
  background: #297cc8;
  height: 32px;
  top: 0px;
  color: #fff;
  padding: 9px 4px;
}

.block-section h2 {
  margin: 0;
  color: #2666a3;
  font-size: 17px;
}

.small h3 {
  margin: 0;
  color: #2666a3;
  font-size: 13px;
}

.small h3 i {
  font-size: 12px;
}

.add-card i {
  font-size: 17px;
}

/*  */
.select2-container--default .select2-selection--multiple .select2-selection__clear {
  font-weight: 100;
  margin-top: -2px;
  margin-right: 0;
}

.select2-container--default .select2-selection--multiple .select2-selection__rendered {
  height: 20px;
