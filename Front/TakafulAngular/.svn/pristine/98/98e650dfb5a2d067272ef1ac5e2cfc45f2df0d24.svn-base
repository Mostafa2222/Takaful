/**********************************************Shared***********************************************/
.headerTitle {
  /* border:1px solid red; */
  margin-top: 4px !important;
  padding-left: 5px !important;
  font: 100 20px/32px Verdana, Geneva, sans-serif;
}

.toolbar {
  background: linear-gradient(to bottom, #ffffff 0%, #bedaf6 100%) !important;
}

.border {
  border: 1px solid saddlebrown;
}

.filiter {
  width: 100%;
  height: 36px;
  margin-top: 3px;
  /* border: 1px solid red; */
}

.Cursor {
  cursor: pointer;
}

.req {
  color: red !important;
}

.btnSave {
  background-color: transparent !important;
  outline: none !important;
  color: #337ab7 !important;
  font-size: medium;
  margin-right: 4px;
  margin-left: 4px;
  cursor: pointer !important;
}

.ActionContent {
  direction: rtl;
  font-size: 17px;
}

.notValid {
  color: red;
}

input.notValid {
  border-color: #dc3545 !important;
}

input.ng-dirty.ng-invalid {
  color: red;
}

.form-control,
.input-group-text {
  border: 1px solid #0080ff;
}

input.ng-touched.ng-invalid {
  border-color: #dc3545;
}

input.ng-valid {
  border-color: #28a745;
}

.green-icon {
  color: #28a745;
}

.red-icon {
  color: #dc3545;
}

.ng-invalid[required],
.ng-invalid.required {
  border: 1px solid red !important; /* green */
}


/* .ng-invalid:not(form) {
  border-left: none !important; /* red */


/*spinner-container*/
.spinner-container {
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #fafafa;
  box-shadow: 0 5px 5px -3px rgba(0, 0, 0, .2), 0 8px 10px 1px rgba(0, 0, 0, .14), 0 3px 14px 2px rgba(0, 0, 0, .12)
}

/*
@media (min-width: 768px) {.col-sm-5ths {width: 20%;float: left;}}
@media (min-width: 992px) {.col-md-5ths {width: 20%;float: left;}}
@media (min-width: 1200px) {.col-lg-5ths {width: 20%;float: left;}}
/*  */
.priority-status {
  height: 8px;
  background: #fffcfc;
  border-radius: 9px;
}

td .priority-status {
  height: 10px;
  border-radius: 9px;
  width: 32px;
  margin: auto;
  margin-bottom: 2px;
}

.high {
  background: #c23531;
}

.low {
  background: #0da551;
}

.normal {
  background: #f8c400;
}

/*  */
.text-red {
  color: red;
}

.block-section {
  border: 1px solid #d2e1ee;
  padding: 5px 15px 9px;
  margin: 4px 0 10px 0;
}

.filter-box {
  padding: 10px 15px;
  max-height: 400px;
  background: #fff;
  position: absolute;
  top: 0px;
  display: none;
  right: 0;
  text-align: left;
  border: 1px solid #abc5de;
  box-shadow: 0px 0px 6px rgba(72, 69, 69, 0.43);
  z-index: 999;
  left: 4px;
}

#groupBy.filter-box {
  right: 10px;
}

/* board */
.form-title {
  background: #d2e1ee;
  color: #297cc8 !important;
  padding: 6px 15px;
  font-size: 14px;
  margin-bottom: 3px;
  position: relative;
}

/*  */
.pb-0 {
  padding-bottom: 0;
}

legend.scheduler-border {
  font-size: 13px;
}

.dataTables_info { /*! text-align: left; */
  font-size: 10px;
}

.t-add {
  font-size: 15px;
}

.postponed-date {
  color: #fe5353;
  text-align: right;
  padding: 5px 10px 2px 0;
  position: relative;
}

.postponed-date::before {
  content: "\f3e5";
  position: absolute;
  right: 83px;
  top: 1px;
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 12px;
  color: #fe5353;
  rotate: -94deg;
}

.form-title .side-collaps {
  position: absolute;
  left: -17px;
  background: #297cc8;
  height: 32px;
  top: 0px;
  color: #fff;
  padding: 9px 4px;
}

.block-section h2 {
  margin: 0;
  color: #2666a3;
  font-size: 17px;
}

.small h3 {
  margin: 0;
  color: #2666a3;
  font-size: 13px;
}

.small h3 i {
  font-size: 10px;
}

.add-card i {
  font-size: 17px;
}

/*  */
.select2-container--default .select2-selection--multiple .select2-selection__clear {
  font-weight: 100;
  margin-top: -2px;
  margin-right: 0;
}

.select2-container--default .select2-selection--multiple .select2-selection__rendered {
  height: 20px;
  line-height: 18px;
}

.select2-results__option i {
  font-size: 20px;
}

.select2-icon span > i {
  font-size: 20px;
}

/*  */
.filter-btn.select {
  background-color: #ffbb00;
  color: #333;
}

/*  */
.footer-form { /*! border: 1px solid #d2e1ee; */
  margin-top: 12px;
  background: #d2e1ee;
  padding: 7px 10px 0px; /*! line-height: 20px; *//*! text-align: right; */
}

.footer-form i {
  font-size: 18px;
}

.footer-form .select2 {
  width: 200px !important;; /*! margin: 5px 0 5px; *//*! float: left; */
}

/*  */
.popover-content {
  padding: 5px;
}

.menu_popup .popup-overlay {
  padding: 0;
  width: auto;
}

.popup-overlay {
  border: solid 1px rgb(204, 204, 204);
  background-color: rgb(255, 255, 255);
  padding: 2px 6px;
  box-shadow: 0px 0px 12.74px 0.26px rgba(0, 0, 0, 0.23);
  width: 150px;
  z-index: 600;
  position: fixed;
}

/*  */
.childTable {
  margin: 5px 0 2px;
}

.table thead {
  background: #337ab7;
}

.dataTables_paginate {
  background: #337ab7;
}

.childTable .table thead th {
  font-size: 10px;
  font-weight: 400;
}

/*  */
#setupDetailsTabel span {
  line-height: 16px;
}

table .text-success {
  color: green;
}

.box-red, .box-yellow, .box-green {
  width: 40px;
  height: 7px;
  margin: 3px auto 0;
  border-radius: 3px; /*! display: inline-block; */
}

.box-yellow {
  background: #FB0;
}

.box-small {
  width: 25px;
  height: 7px;
  border-radius: 3px;
  margin: auto;
}

.box-red {
  background: red;
}

.box-green {
  background: green;
}

.filter-action ul { /*! display: inline-flex; */
  margin: 5px 0 0;
}

.filter-action li {
  margin-right: 15px;
  line-height: 11px;
  border-radius: 7px;
  background: #337ab7;
  margin: 10px auto; /*! font-size: 10px; */
}

.filter-action li.inactive, .filter-action li.inactive .icon, .filter-action li.inactive:hover {
  background: #b7b7b7;
  cursor: not-allowed;
}

.filter-action li.inactive a {
  cursor: not-allowed;
}

.filter-action li a {
  color: #fff;
  width: 100%;
  display: inline-block;
}

.filter-action li:hover {
  background: #1c3e5f;
  border-radius: 17px;
}

.filter-action li .icon {
  display: inline-block; /*! margin-right: 2px; */
  font-size: 15px;
  color: #fff;
  background: #1c3e5f;
  padding: 8px 3px;
  border-radius: 7px 0 0 7px;
  width: 35px; /*! height: 30px; */
  text-align: center;
}

.filter-action li .content-text {
  display: inline-block; /*! padding: 0 0 0 0; */
  vertical-align: middle;
  margin-bottom: 3px;
}

.filter-action li .content-text .number {
  font-size: 11px;
  font-weight: 600; /*! color: #1c3e5f; */
}

.viewBy img {
  width: 60px;
  height: 60px;
  border-radius: 100%;
  opacity: 0.3;
  border: 1px solid #393535;
}

.viewBy label {
  cursor: pointer;
  font-weight: 400;
  color: #333;
  font-size: 13px;
}

.viewBy span.select {
  font-weight: 600;
  color: #1c3e5f;
}

.viewBy img.select {
  opacity: 1;
  box-shadow: 1px 2px 4px #6a6a6a94;
  border: 3px solid #fb0;
}

.viewBy input {
  opacity: 0;
  margin: 0;
}

.barcode-img {
  border: 1px solid #b3b0b0;
  padding: 5px;
  text-align: center;
  margin-top: 20px;
}

.barcode-img img {
  max-height: 130px;
}

.table > thead > tr > td, .table > thead > tr > th {
  font-weight: 600;
}

/*  */
.info-section {
  border: 1px solid #b8cad9;
  padding: 10px 10px 5px;
  box-shadow: 0px 0px 6px #4444;
  background: #fff;
}

.info-section h3 {
  font-weight: 700;
  border-bottom: 1px solid #b8cad9;
  padding-bottom: 5px;
}

.info-section h4 {
  font-weight: 700; /* border-bottom: 1px solid #b8cad9; *//* padding-bottom: 0; */
  font-size: 11px;
  margin: 6px 0 2px;
}

/*  */
.light-red {
  color: #E91E63 !important;
}

.orange {
  color: #db4f0e !important;
}

.light-green {
  color: green !important;
}

/*  */
.square-icon.select {
  color: #f8c400 !important;
}

.square-icon i {
  font-size: 15px;
}

.square-icon i.fa-plus {
  font-size: 10px;
}

.square-icon.select i.fa-plus {
  color: #fff !important;
  background: #f8c400 !important;
  font-size: 10px;
}

.row-inline-editable.active .based-Frequency input {
  width: auto !important;
  margin-right: 3px;
}

/*  */
.row-inline-editable div.t-div {
  display: none;
}

.row-inline-editable.active div.t-div {
  display: inline;
}

td .square-icon i {
  font-size: 10px;
}

.row-inline-editable.active input, .row-inline-editable.active select {
  width: 100% !important;
}

.row-inline-editable.active input[type=radio] {
  width: auto !important;
}

.row-inline-editable span.editable.box-small {
  display: inline-block !important;
}

/*  */
.bg-filter .bg-filter {
  background-color: #fff;
  border: 2px solid #d2e1ee;
  border-bottom-width: 1px;
}

/*  */
.actions .tooltip, table .tooltip, .block-section .tooltip, fieldset .tooltip, .assets-defin .tooltip {
  background: #1e4367;
  color: #f7f7f7;
  width: auto;
  border-radius: 3px;
  box-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
  padding: 0px;
}

.actions .tooltip .tooltip-arrow, table .tooltip .tooltip-arrow, .block-section .tooltip .tooltip-arrow, fieldset .tooltip .tooltip-arrow, .assets-defin .tooltip .tooltip-arrow {
  border: none;
}

.status-box {
  border-radius: 3px;
  padding: 0px 4px;
  text-align: center;
}

.add-type a {
  display: inline-flex;
  background: #337ab7;
  color: #fff;
  margin-right: 10px;
  border-radius: 4px;
  height: 30px;
  width: 15%;
}

.add-type a .icon-box {
  padding: 3px 7px 0;
  font-weight: 600;
  color: #fff;
  font-size: 21px;
}

.add-type a .content-box {
  padding: 6px 15px 0 0;
  font-size: 13px;
}

.add-type a.select .icon-box {
  background-color: rgba(0, 0, 0, 0);
}

.add-type a:hover, .add-type a.select {
  background: #337ab7;
  color: #fff;
}

.add-type a.inactive {
  background: #b7b7b7 !important;
  cursor: pointer;
  color: #fff !important;
}

.add-type a.inactive.initiation-btn .icon-box {
  color: #fff;
}

.initiation-status {
  background: #ffc356;
  color: #4d402b;
}

.review-status {
  background: #d5181f;
  color: #fff;
}

.new-status {
  background: #10961a;
  color: #fff;
}

.in-prog-status {
  background: #00BCD4;
}

.hold-status {
  background: #ff9800;
  color: #fff;
}

.completed-status {
  background: #65863f;
  color: #fff;
}

.reject-status {
  background: #A10404;
  color: #fff;
}

.order-filter a.inactive.completed-btn, .order-filter a.inactive.hold-btn, .order-filter a.inactive.cancel-btn {
  background: #fff !important;
  color: #979595 !important;
}

.order-filter a.inactive.completed-btn .icon-box, .order-filter a.inactive.hold-btn .icon-box, .order-filter a.inactive.cancel-btn .icon-box {
  color: #b7b7b7 !important;
}

.order-filter a.completed-btn, .order-filter a.hold-btn, .order-filter a.cancel-btn {
  background: #fff;
  color: #333352;
  height: auto;
  border-radius: 0;
  margin-top: 6px;
}

.order-filter a.completed-btn .icon-box, .order-filter a.hold-btn .icon-box, .order-filter a.cancel-btn .icon-box {
  padding: 0;
  border-radius: 0;
  background-color: #fff;
}

.order-filter a.completed-btn .icon-box {
  color: #65863F;
}

.order-filter a.hold-btn .icon-box {
  color: #FF9800;
}

.order-filter a.cancel-btn .icon-box {
  color: #A10404;
}

.order-filter a.completed-btn .content-text, .order-filter a.hold-btn .content-text, .order-filter a.cancel-btn .content-text {
  padding-top: 5px;
}

.Order-view a {
  color: #737374;
  margin-left: 8px;
}

.Order-view a.selected {
  color: #337ab7;
  font-weight: 600;
}

.Order-view i {
  font-size: 16px;
}

textarea {
  height: unset;
}

/*  */
.viewBy label i {
  width: 60px;
  height: 60px;
  border-radius: 100%;
  opacity: 0.3;
  border: 1px solid #393535;
  color: #797772;
  padding: 11px 13px;
}

.viewBy label i.select {
  opacity: 1;
  box-shadow: 1px 2px 4px #6a6a6a94;
  border: 3px solid #fb0;
  color: #fb0;
}

.indicator-main a {
  position: relative;
}

.light-blue textarea {
  min-height: 40px;
  height: 0;
}

.w70.ml-20 {
  margin-left: 20% !important;
}

/*  */
table .action a i {
  font-size: 15px;
}

.sending-way i {
  font-size: 20px;
  color: #186db6;
}

.need-action {
  text-align: center;
}

.need-action i {
  font-size: 15px;
  color: #186db6;
}

/*  */
.tabs-left {
  border-bottom: none;
  padding-top: 2px;
  border-right: 1px solid #ddd0;
}

.tabs-left > li {
  float: none; /* margin-bottom: 2px; */
}

.tabs-left > li {
  margin-right: -1px;
  line-height: 11px;
}

.tabs-right > li {
  margin-left: -1px;
}

.tabs-left > li.active > a:focus {
  background: #ffc356;
  color: #141313;
}

.tabs-right > li.active > a, .tabs-right > li.active > a:hover, .tabs-right > li.active > a:focus {
  border-bottom: 1px solid #ddd;
  border-left-color: transparent;
}

.tabs-left > li > a, .tabs-left > li ul.sub li > a {
  display: block;
  border-radius: 0;
  background: #fff;
  color: #585757;
  padding: 7px;
  font-size: 13px;
  line-height: 15px;
  text-transform: none;
  margin: 2px 0;
}

.tabs-left > li ul.sub li > a {
  margin-left: 10px;;
}

.tabs-left > li.active > a, .tabs-left > li.active > a:hover, .tabs-left > li.active > a:focus,
.tabs-left > li ul.sub li > a:hover {
  background: #cde2f8;
  color: #141313;
  border-radius: 0;
  border-bottom: none;
}

.tabs-left > li.disabled > a, .tabs-left > li.disabled > a:hover,
.tabs-left > li.disabled > a:focus {
  background: #f4f4f4;
  color: #8e8e8e;
  border-radius: 4px 0 0 4px;
  border-bottom: none;
}

.tabs-left > li .s-sub::before {
  color: #555;
  font-size: 13px;
  top: 8px;
  right: 5px;
}

.tabs-left > .has-sub a.s-sub.opened::before {
  top: 7px;
}

.tabs-left > li .sub {
  background: #fff;
  color: #141313;
}

.tabs-right > li > a {
  margin-right: 0;
}

.tab-content.verticalTabs > .tab-pane {
  display: none;
}

.tab-content.verticalTabs > .active {
  display: block;
}

/*  */
.user-img {
  border: 1px solid #b0afaf;
  height: 60px;
  width: 60px;
  margin-right: 6px;
  text-align: center;
}

.user-img i {
  color: #a8a6a6;
  font-size: 37px;
  line-height: 54px;
}

.user-info {
  margin-top: 8px;
  color: #297cc9;
  font-weight: 600;
}

.user-info span {
  color: #666;
  font-weight: 500;
}

.priority-btn {
  width: 30px;
  height: 15px;
  display: inline-block;
  margin: 1px 2px 0;
  border-radius: 6px;
}

.priority-btn.high.unselect {
  background: #c2353178;
}

.priority-btn.low.unselect {
  background: #0da55178;
}

.priority-btn.normal.unselect {
  background: #f8c40078;
}

.nav > li > a:focus, .nav > li > a:hover, .head .open > a, .head .open > a:hover, .head .open > a:focus {
  background-color: #cde2f8;
}

.slider-num {
  text-align: center;
  float: left;
  width: 40px;
  margin-left: 10px;
  background: #224b72;
  border: 0px solid #cde3f8;
  position: relative;
  border-radius: 3px;
  height: 20px; /*! line-height: 20px; */
  color: #fff;
}

.slider-num input[type="text"] {
  background: transparent;
  border: none;
  padding: 0 !important;
  text-align: center;
  margin-bottom: 0;
  height: 18px;
}

.slider-num:after {
  position: absolute;
  top: 5px;
  left: -5px;
  width: 0;
  height: 0;
  border-top: 6px solid transparent;
  border-right: 6px solid #224b72;
  border-bottom: 6px solid transparent;
  content: '';
}

#slider-range-max .ui-slider-range {
  background: #234d76;
}

#slider-range-max .ui-state-default, .ui-widget-content .ui-state-default {
  background: none;
  background-color: #FFF;
}

.form-group i {
  font-size: 17px !important;
  color: #0463bf;
}

.form-group i:hover {
  color: #0463bfab;
}

.form-group input[type="checkbox"], .form-group input[type="radio"] {
  margin-top: -2px
}

.nav-item i {
  margin-right: 2px;
  font-size: 15px;
}

.add-msg {
  text-align: center;
  margin-top: 10%;
  color: #337ab7;
}

.add-msg h3 {
  font-size: 20px; /*! color: #777; */
  margin-top: 30px;
}

.add-msg i {
  font-size: 5em;
  background: #337ab7;
  color: #fff;
  border-radius: 100%;
  padding: 15px;
}

.btn i {
  color: #fff !important; /*! font-size: 22px !important; *//*! line-height: 20px; */
}

.open-original-btn {
  position: relative;
}

.open-original-btn i {
  font-size: 13px !important;
  top: 2px;
  position: absolute;
  left: 5px;
}

.open-original-btn input[disabled] {
  cursor: pointer;
}

#open-original {
  margin-top: 11%;
}

