}

table .text-success {
  color: green;
}

.box-red, .box-yellow, .box-green {
  width: 40px;
  height: 7px;
  margin: 3px auto 0;
  border-radius: 3px; /*! display: inline-block; */
}

.box-yellow {
  background: #FB0;
}

.box-small {
  width: 25px;
  height: 7px;
  border-radius: 3px;
  margin: auto;
}

.box-red {
  background: red;
}

.box-green {
  background: green;
}

.filter-action ul { /*! display: inline-flex; */
  margin: 5px 0 0;
}

.filter-action li {
  margin-right: 15px;
  line-height: 11px;
  border-radius: 7px;
  background: #337ab7;
  margin: 10px auto; /*! font-size: 10px; */
}

.filter-action li.inactive, .filter-action li.inactive .icon, .filter-action li.inactive:hover {
  background: #b7b7b7;
  cursor: not-allowed;
}

.filter-action li.inactive a {
  cursor: not-allowed;
}

.filter-action li a {
  color: #fff;
  width: 100%;
  display: inline-block;
}

.filter-action li:hover {
  background: #1c3e5f;
  border-radius: 17px;
}

.filter-action li .icon {
  display: inline-block; /*! margin-right: 2px; */
  font-size: 15px;
  color: #fff;
  background: #1c3e5f;
  padding: 8px 3px;
  border-radius: 7px 0 0 7px;
  width: 35px; /*! height: 30px; */
  text-align: center;
}

.filter-action li .content-text {
  display: inline-block; /*! padding: 0 0 0 0; */
  vertical-align: middle;
  margin-bottom: 3px;
}

.filter-action li .content-text .number {
  font-size: 11px;
  font-weight: 600; /*! color: #1c3e5f; */
}

.viewBy img {
  width: 60px;
