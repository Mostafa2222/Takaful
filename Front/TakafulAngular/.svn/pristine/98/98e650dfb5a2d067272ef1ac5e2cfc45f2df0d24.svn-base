/*  */
.bg-filter .bg-filter {
  background-color: #fff;
  border: 2px solid #d2e1ee;
  border-bottom-width: 1px;
}

/*  */
.actions .tooltip, table .tooltip, .block-section .tooltip, fieldset .tooltip, .assets-defin .tooltip {
  background: #1e4367;
  color: #f7f7f7;
  width: auto;
  border-radius: 3px;
  box-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
  padding: 0px;
}

.actions .tooltip .tooltip-arrow, table .tooltip .tooltip-arrow, .block-section .tooltip .tooltip-arrow, fieldset .tooltip .tooltip-arrow, .assets-defin .tooltip .tooltip-arrow {
  border: none;
}

.satus-box {
  border-radius: 3px;
  padding: 0px 4px;
}

.order-filter a {
  display: inline-flex;
  background: #fbfbfb;
  color: #fff;
  margin-right: 4px;
  border-radius: 4px;
  height: 32px;
}

.order-filter a .icon-box {
  padding: 4px 5px 0;
  border-radius: 2px 0px 0px 2px;
  font-weight: 600;
  color: #fff;
  font-size: 23px;
  background-color: rgba(0, 0, 0, 0.12);
}

.order-filter a .content-box {
  padding: 0 7px; /*! display: inline-block; */
}

.order-filter a .number-box {
  font-weight: 600;
  margin-top: -2px;
}

.order-filter a.initiation-btn {
  background: #ffc356;
  color: #4d402b;
}

.order-filter a.all-btn {
  background: #337ab7;
  color: #fff;
}

a.all-btn .icon-box {
  padding: 11px 5px 5px;
  font-size: 16px;
}

.order-filter a.initiation-btn .icon-box {
  color: #4d402b;
}

.order-filter a.review-btn {
  background: #c12e34;
}

.order-filter a.approv-btn {
  background: #10961a;
}

.order-filter a.in-prog-btn {
  background: #00BCD4;
}

.order-filter a.select .icon-box {
  background-color: rgba(0, 0, 0, 0);
}

.order-filter a:hover.initiation-btn, .order-filter a.initiation-btn.select {
  background: #e8ad42;
  color: #4d402b;
}

.order-filter a:hover.review-btn, .order-filter a.review-btn.select {
  background: #9f191e;
}

.order-filter a:hover.approv-btn, .order-filter a.approv-btn.select {
  background: #0b6f13;
}

.order-filter a:hover.in-prog-btn, .order-filter a.in-prog-btn.select {
  background: #0594a6;
}

.order-filter a.inactive {
  background: #b7b7b7 !important;
  cursor: pointer;
  color: #fff !important;
}

.order-filter a.inactive.initiation-btn .icon-box {
  color: #fff;
}

.initiation-status {
  background: #ffc356;
  color: #4d402b;
}

.review-status {
  background: #d5181f;
  color: #fff;
}

.approve-status, .release-status {
  background: #10961a;
  color: #fff;
