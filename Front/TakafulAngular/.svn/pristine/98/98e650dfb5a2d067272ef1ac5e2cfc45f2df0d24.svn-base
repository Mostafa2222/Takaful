.vertical-align-center {display: table-cell;vertical-align: middle;}
.modal-content {width:inherit;height:inherit;margin: 0 auto;} */

/*  */
.mt-popup-10 {
  margin-top: 10%;
}

.center-header i {
  font-size: 36px;
  margin-left: 12px;
}

.btn.btn-danger {
  color: #fff;
  font-size: 12px;
  line-height: 20px;
  border-radius: 0px;
  padding: 0px 10px;
  -webkit-transition: all ease 0.3s;
  transition: all ease 0.3s;
  overflow: hidden;
}

.btn-primary i {
  color: #fff !important;
}

.form-control.datepicker2[disabled] {
  color: #444 !important;
}

.detail-header .btn.btn-primary {
  border: none !important;
}

.detail-header .btn.btn-primary:hover {
  background: #fdae0e !important;
}


