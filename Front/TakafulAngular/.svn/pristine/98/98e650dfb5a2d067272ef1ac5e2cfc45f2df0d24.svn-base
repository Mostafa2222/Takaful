  border-bottom: 1px solid #6b6b6b !important;
}

.report-item .label {
  font-size: 12px;
  font-weight: 600;
  padding-left: 0;
}

.table-nobg > tfoot > tr > td, .table-nobg > tfoot > tr > th, .table-nobg > thead > tr > td, .table-nobg > thead > tr > th {
  font-size: 11px !important;
  font-weight: 600 !important;
}

