.report-filter {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}

.justify-content-start {
  justify-content: start;
}

.report-item .label {
  font-size: 12px;
  font-weight: 600;
  padding-left: 0;
}

label, .label {
  font-weight: 100;
  color: #296dac;
  text-transform: capitalize;
}

.report .contents {
  margin-top: 0;
  overflow-y: unset;
  height: auto;
  margin-bottom: 0;
}

.report {
  font-size: 12px;
  overflow: auto !important;


}

.report .footer {
  background: #fff;
  text-align: center;
  border-top: 1px solid #9b9b9b;
  margin-top: 20px;
  padding: 4px 30px;
  bottom: 0;
  width: 100%;
  right: auto;
  left: auto;
  width: calc(100% - 30px);
}

.powered {
  font-size: 10px;
}

.print-popup ul li a.pdf {
  color: #a50404;
}

.report .actions a {
  line-height: 30px;
  height: 30px;
  width: 30px;
}

.print-popup {
  border: solid 1px rgb(204, 204, 204);
  background-color: rgb(255, 255, 255);
  box-shadow: 0px 2px 2px 0px rgba(0, 0, 0, 0.19);
  text-align: center;
  padding: 1px 5px;
  position: absolute;
  z-index: 500;
  right: 30px;
  margin-top: 2px;
}

.report .actions a {
  line-height: 30px;
  height: 30px;
  width: 30px;
}

.actions a {
  float: right;
  display: inline-block;
  line-height: 40px;
  height: 40px;
  width: 40px;
  position: relative;
  text-align: center;
  font-size: 16px;
  color: #0463bf;
  -webkit-transition: all ease 0.3s;
  transition: all ease 0.3s;
}

.printBtn {
  cursor: pointer;
  font-size: 18px;
  position: relative;
  top: 2px;
  padding: 0 2px;
}

.print-popup ul {
  margin-bottom: 0;
  display: inline-flex;
}

.print-popup ul li a.excel {
  color: #388708;
}

