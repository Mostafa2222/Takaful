.calc-size-btn {
  background: #b7d2ee;
  padding: 2px 14px;
  border-radius: 3px 3px 3px 0;
  margin: -10px 0 4px -16px;
  width: fit-content;
}

.calc-size-hint::after {
  content: "start calc ...";
  font-size: 10px;
  color: #958e8e;
  text-align: left;
  position: absolute;
  min-width: 48px;
  left: 47px;
  line-height: 10px;
}

