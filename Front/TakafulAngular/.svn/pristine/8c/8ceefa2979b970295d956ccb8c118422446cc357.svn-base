

/*************************************************** filter collapse **********************************************/

.bg-filter {
    background-color: #fff;
    border: 2px solid #d2e1ee;
    border-bottom-width: 0;
}

.filter-collapse {
    position: relative;
    margin-bottom: 15px;
    border-bottom: 2px solid #d2e1ee;
}

.filter-collapse .glyphicon {
    position: absolute;
    background: #d2e1ee;
    color: #21486e;
    left: 50%;
    z-index: 200;
    top: 0px;
    width: 30px;
    padding: 3px;
    text-align: center;
    font-size: 10px;
    cursor: pointer;
    transition: all 0.4s;
    -webkit-transition: all 0.4s;
    -moz-transition: all 0.4s;
    -o-transition: all 0.4s;
    -ms-transition: all 0.4s;
}
