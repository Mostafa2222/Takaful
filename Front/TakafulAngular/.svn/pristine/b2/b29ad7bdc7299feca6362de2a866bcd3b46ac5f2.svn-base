/* Style the entire tree container */



/* :host ::ng-deep .p-tree .p-treenode-children #tree-en{
  position: relative;
  padding-left: 20px dotted black;
}

:host ::ng-deep .p-tree .p-treenode-children::before #tree-en{
  content: '';
  position: absolute;
  left: 10px;
  top: 0;
  bottom: 0;
  width: 0;
  border-left: 1px dotted black;
} */
:host ::ng-deep .tree-en .p-treenode-children {
  position: relative;
  padding-left: 20px;
}

:host ::ng-deep .tree-en .p-treenode-children::before {
  content: '';
  position: absolute;
  left: 10px;
  top: 0;
  bottom: 0;
  border-left: 1px dotted black;
}

:host ::ng-deep .tree-ar .p-treenode-children {
  position: relative;
  padding-right: 20px; /* Adjust for RTL */
}

:host ::ng-deep .tree-ar .p-treenode-children::before {
  content: '';
  position: absolute;
  right: 10px; /* Adjust for RTL */
  top: 0;
  bottom: 0;
  border-right: 1px dotted black;
}
:host ::ng-deep .tree-en .p-tree .p-treenode > .p-treenode-content::before {
  content: '';
  position: absolute;
  /* top: 12px; */
  left: -10px; /* For LTR */
  width: 20px;
  height: 1px;
  background-color: black;
}
:host ::ng-deep .p-tree .p-treenode.first-top-node > .p-treenode-content::before {
  display: none;
}
:host ::ng-deep .tree-ar .p-tree .p-treenode > .p-treenode-content::before {
  content: '';
  position: absolute;
  /* top: 12px; */
  right: -10px; /* Adjust for RTL */
  width: 20px;
  height: 1px;
  background-color: black;
}
::ng-deep .p-tree-container{
  margin-bottom: 0rem !important;
  padding-left: 0rem !important ;
  padding-right: 0rem !important ;
  font-size: 14px;
}

.treeActions
{
    /* border: 1px solid red; */
    font-size: 16px;
    color: rgba(23, 149, 153, 1);
    margin-left: 20px;
    cursor: pointer !important;
}
.treeActions i
{
    margin-right: 5px;
}
.accordion-item{
  margin-bottom: 0rem;
}
.highlight {
  /* background-color: yellow; */
  font-weight: bold;
}
.list-item:hover {
  background-color: #e0f7fa;
  cursor: pointer;
  transition: background-color 0.3s ease;
}
.list-item-hover:hover {
  background-color: var(--appColor);
}
/* Custom class to apply background color on hover */
.hovered {
  background-color: var(--appColor) !important;
  color: #e0f7fa;
}

:host ::ng-deep .tree-ar .p-tree .p-treenode[aria-expanded="false"] .p-tree-toggler {
  transform: rotate(180deg);
}

.page-info {
  color: #007bff; /* Or any color you prefer */
  font-size: 1rem; /* Adjust the size */
  font-weight: bold;
  padding: 10px;
}

.pagination .btn-outline-primary.active {
  background-color: #007bff;  /* Highlight color */
  color: white;               /* Text color */
  border-color: #007bff;      /* Border color */
}

/* Optional: Add a hover effect for other buttons */
.pagination .btn-outline-primary:hover {
  background-color: #f0f8ff; /* Light background on hover */
  border-color: #007bff;
}
#pause {
	display: block;
	background:
		rgba(0, 0, 0, 0.66)
		no-repeat
		0 0;
	width: 100%;
	height: 100%;
	position: fixed;
	bottom: 0;
	left: 0;
	z-index: 1000;
}
.loader {
  transform: rotateZ(45deg);
  perspective: 1000px;
  border-radius: 50%;
  width: 48px;
  height: 48px;
  color: #fff;
}
  .loader:before,
  .loader:after {
    content: '';
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: inherit;
    height: inherit;
    border-radius: 50%;
    transform: rotateX(70deg);
    animation: 1s spin linear infinite;
  }
  .loader:after {
    color: #FF3D00;
    transform: rotateY(70deg);
    animation-delay: .4s;
  }

@keyframes rotate {
  0% {
    transform: translate(-50%, -50%) rotateZ(0deg);
  }
  100% {
    transform: translate(-50%, -50%) rotateZ(360deg);
  }
}

@keyframes rotateccw {
  0% {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  100% {
    transform: translate(-50%, -50%) rotate(-360deg);
  }
}

@keyframes spin {
  0%,
  100% {
    box-shadow: .2em 0px 0 0px currentcolor;
  }
  12% {
    box-shadow: .2em .2em 0 0 currentcolor;
  }
  25% {
    box-shadow: 0 .2em 0 0px currentcolor;
  }
  37% {
    box-shadow: -.2em .2em 0 0 currentcolor;
  }
  50% {
    box-shadow: -.2em 0 0 0 currentcolor;
  }
  62% {
    box-shadow: -.2em -.2em 0 0 currentcolor;
  }
  75% {
    box-shadow: 0px -.2em 0 0 currentcolor;
  }
  87% {
    box-shadow: .2em -.2em 0 0 currentcolor;
  }
}
:host ::ng-deep .p-contextmenu-root-list {
  margin-bottom: unset;
  display: flex;
  flex-direction: column;
}
:host ::ng-deep .p-menuitem-link {
  display: flex;
  gap: 1rem;
  padding: 0.5rem;
}
:host ::ng-deep .p-menuitem-icon {
  color: var(--appColor);
}

.styled-breadcrumb {
  background: rgba(255, 255, 255, 0.3);
  padding: 6px 10px;
  border-radius: 12px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  text-align: center;
}

.breadcrumb {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  list-style: none;
}

.breadcrumb-item {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  padding: 5px;
  transition: all 0.3s ease-in-out;
}

.breadcrumb-item:hover {
  color: #007bff;
  transform: scale(1.05);
}

.separator {
  font-size: 12px;
  font-weight: bold;
  color: #666;
  padding: 0 5px;
}
