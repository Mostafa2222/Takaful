import { Component, Input } from '@angular/core';
import { ActivatedRoute, Router } from '@angular/router';
import { TranslateService } from '@ngx-translate/core';
import { DmsStpLevelDetailsDTO } from '../../../DTO/DmsStpLevelDetailsDTO';

@Component({
  selector: 'app-timeline',
  templateUrl: './timeline.component.html',
  styleUrl: './timeline.component.css'
})
export class TimelineComponent {
  activeStep: string = 'legal-step';
  companyType: string | any;
  selectedBranch: DmsStpLevelDetailsDTO | any;
  constructor(private router: Router, public translate: TranslateService,
    private route: ActivatedRoute
  ) { }
  ngOnInit() {
    const currentUrl = this.router.url;
    switch (true) {
      case currentUrl.includes('LegalStatus'):
        this.activeStep = 'legal-step'
        break;

      case currentUrl.includes('AdministrationPolicies'):
        this.activeStep = 'policies-step'
        break;

      case currentUrl.includes('DepartmentDefinition'):
        this.activeStep = 'depDef-step'
        break;

      case currentUrl.includes('LocationDefinition'):
        this.activeStep = 'locDef-step'
        break;

      case currentUrl.includes('RelatedCompanies'):
       this.activeStep = 'relatedCompanies-step'
        break;

        case currentUrl.includes('Financial'):
       this.activeStep = 'financial-step'
        break;
      default:
        this.activeStep = 'legal-step'
    }
    const selected = localStorage.getItem('selectedBranch');
     this.companyType = localStorage.getItem('hasRelatedCompanies');
  }
  RouteToLegalStatus() {
    this.activeStep = 'legal-step';
    this.router.navigate(['/Content/LegalStatus']);
  }
  RouteToAdministrationPolicies() {
    this.activeStep = 'policies-step';
    this.router.navigate(['/Content/AdministrationPolicies']);
  }
  RouteToDepartmentDefinition() {
    this.activeStep = 'depDef-step';
    this.router.navigate(['/Content/DepartmentDefinition']);
  }
  RouteToFinancial() {
    this.activeStep = 'financial-step';
    this.router.navigate(['/Content/Financial']);
  }
  RouteToLocationDefinition() {
    this.activeStep = 'locDef-step';
    this.router.navigate(['/Content/LocationDefinition']);
  }
  RouteToRelatedCompanies() {
    this.activeStep = 'relatedCompanies-step';
    this.router.navigate(['/Content/RelatedCompanies']);
  }


}
