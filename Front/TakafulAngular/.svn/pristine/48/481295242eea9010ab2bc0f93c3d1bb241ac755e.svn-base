  otherNatureOfWorkEnglish: string | any;
// Address
  continent:string | any;
  countryGroup:string | any;
  country:string | any;
  region:string | any;
  state:string | any;
  city:string | any;


  longitude: number | any;
  latitude: number | any;
  capital: number | any;

  currancyId: number | any;
  currencyArabic: string | any;
  currencyEnglish: string | any;

  numberOfShares: number | any;
  urlAddress: string | any;
  languageId: number | any;
  languageArabic: string | any;
  languageEnglish: string | any;
  defintionId: number | any;
  definitionCode?: string | any;
  addTransactionUser: string | any;


  countryId: number | any;
  cityId: number | any;
  actAsBranch: string | any;
  active: string | any;
  createPOForSubBranch: string | any;
  invoicePayForSubBranch: string | any;
  chartTypeId: number | any;
  chartTempId: number | any;
  clientId: number | any;
  levelId: number | any;
  parentId: number | any;
  parentAddressId: number | any;
  dataSource: string | any;
