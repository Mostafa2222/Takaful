
/********************************************* Forms *********************************************/

input[type="checkbox"],
input[type="radio"] {
    /*! float: left; */
    display: inline-block;
    margin-top: 2px;
    margin-right: 5px;
}

input[type="checkbox"]+label,
input[type="radio"]+label {
    /*float: left;*/
    display: inline-block;
    vertical-align: baseline;
    margin-bottom: 0;
}

input[type="text"] {
    /* height: 20px; */
    width: 100%;
    padding: 0 3px;
}



input[type="number"] {
    text-align: left;
}

input,
select {
    margin-bottom: 7px;
}

select {
    height: 20px;
}

label {
    display: inline-block;
    /*width:100%;*/
}

.checkbox,
.radio {
    position: relative;
    display: block;
    margin-top: 10px;
    margin-bottom: 10px;
}

fieldset {
    min-width: 0;
    padding: 0;
    margin: 0;
    border: 0;
}

fieldset.scheduler-border {
    border: solid 1px #b7d2ee !important;
    padding: 0 15px 10px;
    border-bottom: none;
    margin-bottom: 15px;
    border-radius: 3px;
}

legend.scheduler-border {
    width: auto !important;
    border: none;
    font-size: 14px;
    color: #1e6bac;
    padding: 0 10px;
    margin-bottom: 5px;
}

.textarea-height {
    height: 108px !important;
}

.input-group {
    display: block;
    ;
}
