$(document).ready(function () {

  $('.childTable table tbody').on('click', 'tr', function () {
    $(this).toggleClass('selected');
    $(this).siblings('tr').removeClass('selected');
  });
  $.fn.dataTable.moment('DD/MM/YYYY');
  //Creat table row .create-row
  $('#mainTabel').on('click', '.create-row', function () {
    $(this).find("i").toggleClass("fa-minus fa-plus");
    $(this).closest("table").find("tr.new-row").toggleClass('active');
  });
    //
  $('#mainTabel').on('click', 'input[name="selectRow"]', function () {
    if ($(this).is(":checked")) {
      $('.filter-action li').removeClass("inactive");
      $(this).parent().parent().addClass('selected')
    } else {
      $('.filter-action li').addClass("inactive");
      $(this).parent().parent().removeClass('selected');
      $(this).parent().parent().parent().siblings().children().children().children('input[name="selectAll"]').prop("checked", false);
    }
  });
  //
  $('#mainTabel').on('click', 'input[name="selectAll"]', function () {
    if ($(this).is(":checked")) {
      $(this).parent().parent().parent().siblings().children().children().find('input[name = "selectRow"]').prop("checked", true).parent().parent().addClass('selected');
      $('.filter-action li').removeClass("inactive");
    } else {
      $(this).parent().parent().parent().siblings().children().children().find('input[name = "selectRow"]').prop("checked", false).parent().parent().removeClass('selected');
      $('.filter-action li').addClass("inactive");
    }
  });
  //Creat table row .create-row
  $('#mainTabel').on('click', '.details-equip', function () {
    $(this).find("i").toggleClass("fa-minus fa-plus");
    $(this).closest("table").find("tr.new-row").toggleClass('active');
    $('.filter-action li').toggleClass("inactive");
  });
  // Row inline Add
  $(document).on("click", ".addNewRow", function () {
    var newRow = $(this).parent().parent().parent().siblings().children().find(".newrow");
    var newRowcontent = newRow.clone().removeClass("newrow");
    newRow.before(newRowcontent);
  });
});
// tables
$(document).ready(function () {
  var tablemain = mainTabel();
  function mainTabel () {
    var table = $('#mainTabel table').DataTable({
      "dom": 'tilp',
      "stateSave": false,
      "scrollCollapse": true,
      "info": true,
      "paging": true,
      "responsive": true,
      "ordering": true,
      "colReorder": false,
      "lengthMenu": [10, 20, 30],
      "rowReorder": false,
      'columnDefs': [{
        'targets': [0,7,8],
        'orderable': false,
      }]
    });
    return table;
  };
  FilterDatatable(tablemain);
//
  var tablesetup = setupTabel();
  function setupTabel () {
    var table = $('#setupTabel table').DataTable({
      "dom": 'tilp',
      "stateSave": false,
      "scrollCollapse": true,
      "info": true,
      "paging": true,
      "responsive": true,
      "ordering": false,
      "colReorder": false,
      "lengthMenu": [10, 20, 30],
      "rowReorder": false,
    });
    return table;
  };
  FilterDatatable(tablesetup);
  //
  ////// authorized
  $('#setupTabel tbody').on('click', 'td a.authorized', function () {
    var tr = $(this).closest('tr');
    var row = $(this).closest('table').DataTable().row(tr);
    $('a').not(this).removeClass('select');
    if (row.child.isShown()) {
      row.child.hide();
      tr.removeClass('shown');
      $(this).removeClass('select');
    } else {
      row.child(format1(row.data())).show();
      tr.addClass('shown');
      tr.removeClass('selected');
      $(this).addClass('select');
    }
  });
  function format1 (rowData) {
    var div = $('<div/>').addClass('loading').text('Loading...');
    div.load("authorized-" + rowData[0] + ".html", function () {
      $(".loading").removeClass('loading');
      div.find("table");
    });
    console.log(rowData[0]);
    return div;
  };
  ////// documents-req
  $('#setupTabel tbody').on('click', 'td a.documents-req', function () {
    var tr = $(this).closest('tr');
    var row = $(this).closest('table').DataTable().row(tr);
    $('a').not(this).removeClass('select');
    if (row.child.isShown()) {
      row.child.hide();
      tr.removeClass('shown');
      $(this).removeClass('select');
    } else {
      row.child(format2(row.data())).show();
      tr.addClass('shown');
      tr.removeClass('selected');
      $(this).addClass('select');
    }
  });
  function format2 (rowData) {
    var div = $('<div/>').addClass('loading').text('Loading...');
    div.load("documents-req-" + rowData[0] + ".html", function () {
      $(".loading").removeClass('loading');
      div.find("table");
    });
    console.log(rowData[0]);
    return div;
  };
  ////// template-items
  $('#setupTabel tbody').on('click', 'td a.template-items', function () {
    var tr = $(this).closest('tr');
    var row = $(this).closest('table').DataTable().row(tr);
    $('a').not(this).removeClass('select');
    if (row.child.isShown()) {
      row.child.hide();
      tr.removeClass('shown');
      $(this).removeClass('select');
    } else {
      row.child(format3(row.data())).show();
      tr.addClass('shown');
      tr.removeClass('selected');
      $(this).addClass('select');
    }
  });
  function format3 (rowData) {
    var div = $('<div/>').addClass('loading').text('Loading...');
    div.load("template-items-" + rowData[0] + ".html", function () {
      $(".loading").removeClass('loading');
      div.find("table");
    });
    console.log(rowData[0]);
    return div;
  };

  ////// Document
  $('#ContractTabel tbody').on('click', 'td a.document', function () {
    var tr = $(this).closest('tr');
    var row = $(this).closest('table').DataTable().row(tr);
    $('a').not(this).removeClass('select');
    if (row.child.isShown()) {
      row.child.hide();
      tr.removeClass('shown');
      $(this).removeClass('select');
    } else {
      row.child(format4(row.data())).show();
      tr.addClass('shown');
      tr.removeClass('selected');
      $(this).addClass('select');
    }
  });
  function format4 (rowData) {
    var div = $('<div/>').addClass('loading').text('Loading...');
    div.load("document-" + rowData[0] + ".html", function () {
      $(".loading").removeClass('loading');
      div.find("table");
    });
    console.log(rowData[0]);
    return div;
  };
  ////// notes
  $('#ContractTabel tbody').on('click', 'td a.notes', function () {
    var tr = $(this).closest('tr');
    var row = $(this).closest('table').DataTable().row(tr);
    $('a').not(this).removeClass('select');
    if (row.child.isShown()) {
      row.child.hide();
      tr.removeClass('shown');
      $(this).removeClass('select');
    } else {
      row.child(format5(row.data())).show();
      tr.addClass('shown');
      tr.removeClass('selected');
      $(this).addClass('select');
    }
  });
  function format5 (rowData) {
    var div = $('<div/>').addClass('loading').text('Loading...');
    div.load("notes-attch-" + rowData[0] + ".html", function () {
      $(".loading").removeClass('loading');
      div.find("table");
    });
    console.log(rowData[0]);
    return div;
  };
});
// select-multiple
$(document).ready(function () {
  // select2
  $(".chosen-single").select2({
    width: "100%"
  });

  // select2 multiselection
  $(".chosen-multiple").select2({
    width: "100%",
    multiple: true,
    dropdownAutoWidth: true,
    allowClear: true,
    closeOnSelect: false,
    tags: true
  });
  //  result of selected items
  $('.chosen-multiple').on('select2:close', function (evt) {
    var uldiv = $(this).siblings('span.select2').find('ul');
    var oldCount = parseInt(uldiv.find('.count').text());
    oldCount = oldCount || 0;
    var count = uldiv.find('li').length - 1 + oldCount;
    console.log($(this).siblings('span.select2').find('count'));
    uldiv.html("<li><span class='count'>" + count + "</span> items selected</li>")
  });

});
$(document).ready(function () {

  //
  $(document).on("click", ".filter-btn", function () {
    $('#groupBy.filter-box').slideUp();
    $('#filter.filter-box').slideToggle();
    $(this).addClass("select")
  });
  // $(document).on("click", ".filterBtn", function () {
  //   $(this).parent().parent().parent().slideToggle();
  // });
  $(document).on("click", ".groupBy-btn", function () {
    $('#filter.filter-box').slideUp();
    $('#groupBy.filter-box').slideToggle();
  });

  //
  $(document).on("click", ".addUploadFile", function (e) {
    e.preventDefault();
    var newFile = $('.uploadFileBlock') /*.first()*/;
    var newFilecontent = newFile.clone().removeClass('uploadFileBlock');
    newFile.before(newFilecontent);
  });
  $(document).on("click", ".btn-remove", function () {
    $(this).parent().parent('.uploadBlock').remove();
  });

  // Row inline Add
  $(document).on('click', '.t-add', function () {
    var newRows = $(this).parent().parent().siblings('.new-row');

    //$('.addRow').hide();

    newRows.toggleClass('active');
    newRows.children('.row-inline-editable').addClass("active");

    newRows.children('.row-inline-editable').each(function (index, value) {
      var text = $(this).children("input[type='text']").val("");
      var checkbox = $(this).children("input[type='checkbox']").val("");
      var select = $(this).children("select").removeAttr('checked');

    });

  });
  // Row inline Add -top add btn in page title-
  $(document).on('click', '.addRowTable', function () {
    var newRow = $(this).parent().parent().siblings().children().children().children().children().children().find('.new-row');
    newRow.toggleClass('active');
    newRow.children('.row-inline-editable').addClass("active");
    newRow.children('.row-inline-editable').each(function (index, value) {
      var text = $(this).children("input[type='text']").val("");
      var checkbox = $(this).children("input[type='checkbox']").val("");
      var select = $(this).children("select").removeAttr('checked');
    });
  });
  // Row inline Add ib sub table
  $(document).on('click', '.add-Row', function () {
    var newRow = $(this).parent().parent().siblings().children().children().children('.new-row');
    newRow.toggleClass('active');
    newRow.children('.row-inline-editable').addClass("active");
    newRow.children('.row-inline-editable').each(function (index, value) {
      var text = $(this).children("input[type='text']").val("");
      var checkbox = $(this).children("input[type='checkbox']").val("");
      var select = $(this).children("select").removeAttr('checked');
    });

  });

});
$(document).ready(function () {
  //grant View-btn agendaView-btn
  $(document).on("click", ".gridView-btn", function () {
    $(this).addClass("selected");
    $(".grantView-btn").removeClass("selected");
    $(".grantView").addClass("dnone");
    $(".gridView").removeClass("dnone");
  });
  $(document).on("click", ".grantView-btn", function () {
    $(this).addClass("selected");
    $(".gridView-btn").removeClass("selected");
    $(".grantView").removeClass("dnone");
    $(".gridView").addClass("dnone");
  });

  //.initiation-btn .review-btn .approv-btn .in-prog-btn .initiation-status .review-status .approv-status .in-prog-status

  $(document).on("click", ".order-filter a", function () {
    $(this).toggleClass("select");
    $('.order-filter a').not(this).removeClass('select').addClass("inactive");
  });

  $(document).on("click", ".initiation-btn", function () {
    $(this).removeClass("inactive");
    $('.review-status, .approv-status, .in-prog-status, .cancelled-status, .hold-status, .completed-status').parent().parent('tr').hide();
    $('.initiation-status').parent().parent('tr').show();

  });
  $(document).on("click", ".review-btn", function () {
    $(this).removeClass("inactive");
    $('.initiation-status, .approv-status, .in-prog-status, .cancelled-status, .hold-status, .completed-status').parent().parent('tr').hide();
    $('.review-status').parent().parent('tr').show();
  });
  $(document).on("click", ".approv-btn", function () {
    $(this).removeClass("inactive");
    $('.review-status, .initiation-status, .in-prog-status, .cancelled-status, .hold-status, .completed-status').parent().parent('tr').hide();
    $('.approv-status').parent().parent('tr').show();
  });
  $(document).on("click", ".in-prog-btn", function () {
    $(this).removeClass("inactive");
    $('.initiation-status, .approv-status, .review-status, .cancelled-status, .hold-status, .completed-status').parent().parent('tr').hide();
    $('.in-prog-status').parent().parent('tr').show();
  });

  $(document).on("click", ".hold-btn", function () {
    $(this).removeClass("inactive");
    $('.initiation-status, .review-status, .approv-status, .in-prog-status, .cancelled-status, .completed-status').parent().parent('tr').hide();
    $('.hold-status').parent().parent('tr').show();
  });
  $(document).on("click", ".cancel-btn", function () {
    $(this).removeClass("inactive");
    $('.initiation-status, .review-status, .approv-status, .in-prog-status, .hold-status, .completed-status').parent().parent('tr').hide();
    $('.cancelled-status').parent().parent('tr').show();
  });
  $(document).on("click", ".completed-btn", function () {
    $(this).removeClass("inactive");
    $('.initiation-status, .review-status, .approv-status, .in-prog-status, .hold-status, .cancelled-status').parent().parent('tr').hide();
    $('.completed-status').parent().parent('tr').show();
  });
  $(document).on("click", ".all-btn", function () {
    $(this).removeClass("inactive");
    $('.initiation-status, .review-status, .approv-status, .in-prog-status, .hold-status, .cancelled-status, .completed-status').parent().parent('tr').show();
    $('.order-filter a').removeClass('select').removeClass("inactive");
  });
});
//hide popup if clicked outside
$(document).click(function (e) {
  var $tgt = $(e.target);
  if ($tgt.closest(".parts-btn,.warranty-btn,.scrapped-btn,.contract-btn").length) { } else {
    $(".parts-popup,.warranty-popup,.scrapped-popup,.contract-popup").hide();
  }
});
