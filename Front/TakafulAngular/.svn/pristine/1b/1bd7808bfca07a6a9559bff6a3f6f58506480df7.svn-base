  styleUrl: './legal-status.component.css',
  animations: [
    trigger('modalAnimation', [
      state('void', style({ opacity: 0, transform: 'translateY(-20px)' })), // Initial state (hidden)
      state('*', style({ opacity: 1, transform: 'translateY(0)' })), // Final state (visible)
      transition(':enter', [
        animate('300ms ease-out'), // Animation for opening
      ]),
      transition(':leave', [
        animate('200ms ease-in', style({ opacity: 0, transform: 'translateY(-20px)' })), // Animation for closing
      ]),
    ]),
