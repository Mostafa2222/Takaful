    FilterDatatable(tableDash);
    // sub table
    //   linked-details
    $('#groupTabel tbody').on('click', 'td a.linked-details', function () {
        // $(this).addClass("selected");
        var tr = $(this).closest('tr');
        var row = $(this).closest('table').DataTable().row(tr);
        if (row.child.isShown()) {
            row.child.hide();
            tr.removeClass('shown');
            $(this).children().removeClass("select fa-ellipsis-v").addClass("fa-ellipsis-h");
        } else {
            row.child(format1(row.data())).show();
            tr.addClass('shown');
            tr.removeClass('selected');
            $(this).children().addClass('select');
            $(this).children("i").toggleClass("fa-ellipsis-h fa-ellipsis-v");
        }
    });
    function format1 (rowData) {
        var div = $('<div/>').addClass('loading').text('Loading...');
        div.load("linked-to-" + rowData[0] + ".html", function () {
            $(".loading").removeClass('loading');
            div.find("table");
        });
        console.log(rowData[0]);
        return div;
    };


