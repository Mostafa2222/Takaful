$(document).ready(function () {
    // Data table Search
    $('.searchableTh .fa-search').click(function () {
        $(this).parent().toggleClass("searching");
        $(this).siblings("input,select").focus();
        $(this).siblings("input,select").val("");
        $(this).siblings("input,select").trigger("change");
        /*table.columns().search( "" ).draw();*/
        event.stopPropagation();
    });
    $('.searchableTh input,.searchableTh select').click(function () {
        event.stopPropagation();
    });
    // Apply the search
    function FilterDatatable (table) {
        table.columns().every(function () {
            var that = this;
            $('input', this.header()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that.search(this.value).draw();
                }
            });
            $('select', this.header()).on('change', function () {
                if (that.search() !== this.value) {
                    //regExSearch = '<span\b[^>]*>('+ this.value +')</span>';
                    //table.column(columnNo).search(regExSearch, true, false).draw();
                    that
                        .search(this.value)
                        .draw();
                    console.log(that.search());
                }
            });
        });
    };
});
$(document).ready(function () {
    $('.chosen-single').select2({
        width: '100%'
    });
    // select2 multiselection
    $('.chosen-multiple').select2({
        width: '100%',
        multiple: true,
        dropdownAutoWidth: true,
        allowClear: true,
        closeOnSelect: false,
        tags: false,
    });
    //  result of selected items
    $('.chosen-multiple').on('select2:close', function (evt) {
        var uldiv = $(this).siblings('span.select2').find('ul')
        var count = uldiv.find('li').length - 1;
        uldiv.html("<li>" + count + " items selected</li>")
    });
    // select2 multiselection
    $('.chosen-multiple-days').select2({
        width: '100%',
        multiple: true,
