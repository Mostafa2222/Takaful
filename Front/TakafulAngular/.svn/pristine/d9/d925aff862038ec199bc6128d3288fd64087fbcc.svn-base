/*********************************************** LOGIN PAGE **********************************************/

.login-container {
    left: 42%;
width: 250px;
margin: 0 auto;
position: absolute;
top: 50%;
-webkit-transform: translateY(-50%);
transform: translateY(-50%);
}

.gl-login-logo {
margin: 0 auto 30px auto;
display: block;
}

.login-input {
height: 30px !important;
margin-bottom: 20px;
text-indent: 5px;
}

.login-btn {
height: 30px !important;
width: 100%;
margin-top: 10px;
cursor: pointer;
position: relative;
z-index: 1000;
-webkit-box-shadow: 0px 30px 30px 0px rgba(48, 50, 50, 0.5);
box-shadow: 0px 30px 30px 0px rgba(48, 50, 50, 0.5);
}
