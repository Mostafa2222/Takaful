                                        <a href="#" class="text-danger delete-row fa fa-trash-alt"></a>
                                    </td>
                                    <td class="row-inline-editable" data-search="219">219</td>
                                    <td class="row-inline-editable" data-search="New Builiding"><span class="editable">
                                            New Builiding</span><input type="text" class="form-control"
                                            value="New Builiding"></td>
                                    <td class="row-inline-editable" data-search="مبنى جديد"><span class="editable"> مبنى
                                            جديد</span><input type="text" class="form-control" value="مبنى جديد"></td>
                                    <td class="row-inline-editable" data-search="2024"><span class="editable">2024
