:host ::ng-deep .p-organizationchart {
    min-width: 100vh;  
    min-height: 100vh;  
    margin: 0 auto;  /* Center the chart */
    overflow: auto;  /* Prevent scroll bars */
    background: #343a40;  /* Light background color */
    border-radius: 8px;  /* Rounded corners */
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);  /* Subtle shadow */
    display: flex;
    align-items: center;
    font-size: 14px;
    font-weight: 600;
  }
  

  
  /* Style the individual nodes in the chart */
  :host ::ng-deep .p-organizationchart-node-content {
    background-color: #dee2e6; 
    color: #212529; 
    border-radius: 5px; 
    /* border-color: ; */
    border: 4px solid #1864ab;
    box-shadow: 0px 6px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease; 
    min-width: 12rem;
  }
  
  /* Hover effect for nodes */
  :host ::ng-deep .p-organizationchart-node-content:hover {
    /* transform: translateY(-5px);  */
    box-shadow: 0px 8px 12px rgba(0, 0, 0, 0.15);
  }
  
  /* Styles for lines connecting the nodes */
  :host ::ng-deep .p-organizationchart-line-left  {
    border-color: #dee2e6 !important;
  }
  :host ::ng-deep .p-organizationchart-line-top  {
    border-color: #dee2e6 !important;
  }
  :host ::ng-deep .p-organizationchart-line-down   {
    background-color: #dee2e6 !important;
  }
  