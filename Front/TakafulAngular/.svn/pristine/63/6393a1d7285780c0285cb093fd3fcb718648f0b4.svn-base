<!-- Under Construction Projects Modal -->
<div class="modal fade" id="AddProjectsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl" style="top: 50%;left: 50%;    transform: translate(-75%, -50%);" >
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="">{{"Organization.Timeline.Financial.Under_Construct.New_Project"
                    |
                    translate}}</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <fieldset class="scheduler-border">
                    <div class="row">
                        <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.Project_Code"
                                |
                                translate}}</label>
                            <input type="text" class="form-control">
                        </div>
                        <div class="col-sm-12 col-md-5 col-lg-5 col-xl-5 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.English_Desc"
                                |
                                translate}}</label>
                            <input type="text" class="form-control">
                        </div>
                        <div class="col-sm-12 col-md-5 col-lg-5 col-xl-5 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.Arabic_Desc"
                                |
                                translate}}</label>
                            <input type="text" class="form-control">
                        </div>
                        <div class="col-sm-12 col-md-4 col-lg-3 col-xl-3 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.Project_Year"
                                |
                                translate}}</label>
                            <input type="text" class="form-control">
                        </div>
                        <div class="col-sm-12 col-md-3 col-lg-3 col-xl-3 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.Emp_Id"
                                |
                                translate}}</label>
                            <input type="text" class="form-control">
                        </div>
                        <div class="col-sm-12 col-md-3 col-lg-3 col-xl-3 form-group">
                            <label class="form-label">
                                {{"Organization.Timeline.Financial.Under_Construct.Start_Project_Date"
                                |
                                translate}}</label>
                            <input type="text" class="form-control from">
                        </div>
                        <div class="col-sm-12 col-md-3 col-lg-3 col-xl-3 form-group">
                            <label class="form-label">
                                {{"Organization.Timeline.Financial.Under_Construct.End_Project_Date"
                                |
                                translate}}</label>
                            <input type="text" class="form-control to">
                        </div>
                        <div class="col-sm-12 col-md-12 col-lg-12 col-xl-12 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.Project_Note"
                                |
                                translate}} </label>
                            <textarea class="form-control max-text-area" rows="3"></textarea>
                        </div>
                        <div class="col-sm-12 col-md-4 col-lg-4 col-xl-4 form-group">
                            <label class="form-label">{{"Organization.Timeline.Financial.Under_Construct.Cost_Center"
                                |
                                translate}} </label>
                            <div class="input-group flex-nowrap drug-code">
                                <input type="text" class="form-control" value="Cost Center" size="11" disabled>
                                <span class="input-group-btn ">
                                    <a href="#" class="btn btn-default" type="button"><i class="fas fa-search"></i></a>
                                </span>
                            </div>
                        </div>
                        <div class="col-sm-12 col-md-4 col-lg-4 col-xl-4 form-group">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" value="" id="flexCheckDefault">
                                <label class="form-check-label"
                                    for="flexCheckDefault">{{"Organization.Timeline.Financial.Under_Construct.Under_Construction"
                                    |
                                    translate}}</label>
                            </div>
                        </div>
                        <div class="col-sm-12 col-md-4 col-lg-4 col-xl-4 form-group">
                            <div class="form-check mt-4">
                                <input class="form-check-input" type="checkbox" value="" id="flexCheckDefault">
                                <label class="form-check-label"
                                    for="flexCheckDefault">{{"Organization.Timeline.Financial.Under_Construct.Project_Assign"
                                    |
                                    translate}}</label>
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger"
                    data-bs-dismiss="modal">{{"Organization.Timeline.Financial.Under_Construct.Close"
                    |
                    translate}}</button>
                <button type="button" class="btn btn-primary"
                    data-bs-dismiss="modal">{{"Organization.Timeline.Financial.Under_Construct.Add"
                    |
                    translate}}</button>
            </div>
        </div>
    </div>
</div>