@font-face {
  font-family: 'production-font';
  src:  url('production-font.eot?waitau');
  src:  url('production-font.eot?waitau#iefix') format('embedded-opentype'),
    url('production-font.ttf?waitau') format('truetype'),
    url('production-font.woff?waitau') format('woff'),
    url('production-font.svg?waitau#production-font') format('svg');
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

[class^="prod-icon-"], [class*=" prod-icon-"] {
  /* use !important to prevent issues with browser extensions that change fonts */
  font-family: 'production-font' !important;
  speak: never;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;

  /* Better Font Rendering =========== */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.prod-icon-route:before {
  content: "\e900";
}
.prod-icon-strategy:before {
  content: "\e901";
}
.prod-icon-conveyor-belt:before {
  content: "\e902";
}
.prod-icon-manufacturing:before {
  content: "\e903";
}
.prod-icon-production:before {
  content: "\e904";
}
.prod-icon-production-1:before {
  content: "\e905";
}
.prod-icon-order:before {
  content: "\e906";
}
.prod-icon-shipping:before {
  content: "\e907";
}
.prod-icon-delivery:before {
  content: "\e908";
}
