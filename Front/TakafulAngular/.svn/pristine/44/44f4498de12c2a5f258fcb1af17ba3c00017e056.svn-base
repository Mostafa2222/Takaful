@font-face {
  font-family: 'EmailFont';
  src:  url('EmailFont.eot?afaprv');
  src:  url('EmailFont.eot?afaprv#iefix') format('embedded-opentype'),
    url('EmailFont.ttf?afaprv') format('truetype'),
    url('EmailFont.woff?afaprv') format('woff'),
    url('EmailFont.svg?afaprv#EmailFont') format('svg');
  font-weight: normal;
  font-style: normal;
  font-display: block;
}

[class^="iconmail-"], [class*=" iconmail-"] {
  /* use !important to prevent issues with browser extensions that change fonts */
  font-family: 'EmailFont' !important;
  speak: never;
  font-style: normal;
  font-weight: normal;
  font-variant: normal;
  text-transform: none;
  line-height: 1;

  /* Better Font Rendering =========== */
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

