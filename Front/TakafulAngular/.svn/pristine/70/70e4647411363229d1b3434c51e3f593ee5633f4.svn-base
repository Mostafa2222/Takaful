/*  */
.modal-confirm {
  /*! color: #636363; */
  /*! font-size: 14px; */
}

.modal-confirm .modal-body {
  padding: 10px 15px 5px;
  font-size: 12px;
  color: #2b2b2b;
  /*! text-align: center; */
}

.modal-confirm .modal-body h3 {
  padding: 10px 15px 0;
  font-size: 15px;
  color: #2b2b2b;
  text-align: center;
  margin-top: 5px;
}

.modal-confirm .modal-content {
  /*! padding: 10px 4px; */
  /*! border-radius: 5px; */
  /*! border: none; */
}

.modal-confirm .modal-header {
  /*! border-bottom: none; */
  position: relative;
}

.modal-confirm h4 {
  /*! text-align: center; */
  /*! font-size: 18px; */
  /*! margin: 10px 0 0px; */
}

.modal-confirm h4 i {
  font-size: 25px;
}

.modal-confirm .form-control,
.modal-confirm .btn {
  min-height: 28px;
  border-radius: 3px;
}

.modal-confirm .close {
  position: absolute;
  top: 2px;
  right: 2px;
}

.modal-confirm .modal-footer {
  border: none;
  text-align: center;
  border-radius: 5px;
  font-size: 13px;
  padding: 5px;
}

.modal-confirm.modal-dialog {
  margin-top: 10%;
}

.modal-confirm .icon-box {
  color: #fff;
  position: absolute;
  margin: 0 auto;
  left: 0;
  right: 0;
  top: -47px;
  width: 65px;
  height: 65px;
  border-radius: 50%;
  z-index: 9;
  padding: 15px;
  text-align: center;
  box-shadow: 0px 2px 2px rgba(0, 0, 0, 0.1);
  background: #214970;
  background: -webkit-gradient(linear, left bottom, left top, from(#214970), to(#337ab7));
  background: linear-gradient(to top, #214970 0%, #337ab7 100%);
  filter: progid:DXImageTransform.Microsoft.gradient(startColorstr='#337ab7', endColorstr='#214970', GradientType=0);
}

.modal-confirm .icon-box i {
  font-size: 30px;
  position: relative;
  top: 3px;
}

.modal-confirm .btn {
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.4s;
  line-height: normal;
  border: none;
  padding: 5px 10px;
}

.modal-confirm .btn:hover,
.modal-confirm .btn:focus {
  outline: none;
}

.modal-confirm .form-group {
  margin: 0 auto;
}

