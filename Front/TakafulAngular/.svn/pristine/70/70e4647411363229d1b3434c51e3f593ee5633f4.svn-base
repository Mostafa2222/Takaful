/*  */
#setupDetailsTabel img,
#setupDetailsTabel1 img,
.table-assets-img {
  width: 40px;
  height: 40px;
}

#setupDetailsTabel span {
  line-height: 16px;
}

table .text-success {
  color: green;
}

.box-red,
.box-yellow,
.box-green {
  width: 40px;
  height: 7px;
  margin: 3px auto 0;
  border-radius: 3px;
  /*! display: inline-block; */
}

.box-yellow {
  background: #FB0;
}

.box-small {
  width: 25px;
  height: 7px;
  border-radius: 3px;
  margin: auto;
}

.box-red {
  background: red;
}

.box-green {
  background: green;
}

.filter-action ul {
  /*! display: inline-flex; */
  margin: 5px 0 0;
}

.filter-action li {
  margin-right: 15px;
  line-height: 11px;
  border-radius: 7px;
  background: #337ab7;
  margin: 10px auto;
  /*! font-size: 10px; */
}

.filter-action li.inactive,
.filter-action li.inactive .icon,
.filter-action li.inactive:hover {
  background: #b7b7b7;
  cursor: not-allowed;
}

.filter-action li.inactive a {
  cursor: not-allowed;
}

.filter-action li a {
  color: #fff;
  width: 100%;
  display: inline-block;
}

.filter-action li:hover {
  background: #1c3e5f;
  border-radius: 17px;
}

.filter-action li .icon {
  display: inline-block;
  /*! margin-right: 2px; */
  font-size: 15px;
  color: #fff;
  background: #1c3e5f;
  padding: 8px 3px;
  border-radius: 7px 0 0 7px;
  width: 35px;
  /*! height: 30px; */
  text-align: center;
}

.filter-action li .content-text {
  display: inline-block;
  /*! padding: 0 0 0 0; */
  vertical-align: middle;
  margin-bottom: 3px;
}

.filter-action li .content-text .number {
  font-size: 11px;
  font-weight: 600;
  /*! color: #1c3e5f; */
}

.viewBy img {
  width: 60px;
  height: 60px;
  border-radius: 100%;
  opacity: 0.3;
  border: 1px solid #393535;
}

.viewBy label {
  cursor: pointer;
  font-weight: 400;
  color: #333;
  font-size: 13px;
}

.viewBy span.select {
  font-weight: 600;
  color: #1c3e5f;
}

.viewBy img.select {
  opacity: 1;
  box-shadow: 1px 2px 4px #6a6a6a94;
  border: 3px solid #fb0;
}

.viewBy input {
  opacity: 0;
  margin: 0;
}

.barcode-img {
  border: 1px solid #b3b0b0;
  padding: 5px;
  text-align: center;
  margin-top: 20px;
}

.barcode-img img {
  max-height: 130px;
}

.table > thead > tr > td,
.table > thead > tr > th {
  font-weight: 600;
}

/*  */
.assets-defin {
  margin: 5px 0 10px 10px;
}

.assets-defin-box {
  text-align: center;
  margin-bottom: 5px;
  z-index: 100;
  margin-top: 5px;
}

.assets-defin-box::after {
  content: "";
  border-bottom: 2px #d2e1ee solid;
  position: absolute;
  width: 100%;
  top: 25px;
  margin-left: 0;
  z-index: 9;
}

.assets-defin-box:last-child::after {
  content: "";
  border-bottom: none;
}

.assets-defin-box .icon-circle {
  position: relative;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: #d2e1ee;
  text-align: center;
  color: #1b3d5e;
  z-index: 100;
}

.assets-defin-box .icon-circle span {
  padding: 0px 0px;
  text-align: center;
}

.assets-defin-box .icon-circle span i {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 12px;
}

.assets-defin-box .icon-circle img {
  border-radius: 100%;
  height: 48px;
  width: 48px;
  margin-top: 1px;
  margin-left: 0px;
}

.assets-defin-box .icon-circle i {
  font-size: 24px;
}

.assets-defin-box .icon-circle::after {
  content: '';
  border: 2px solid #d2e1ee;
  border-radius: 50%;
  width: 60px;
  height: 60px;
  position: absolute;
  left: -4.92px;
  top: -0.4px;
  bottom: 0;
  right: 0;
  margin: auto;
}

.assets-defin-box .icon-circle.active {
  background: #fdae0e;
  color: #fff;
}

.assets-defin-box .icon-circle.active::after {
  border: 2px solid #fdae0e;
}

.indicator-status i {
  font-size: 11px;
  padding: 4px 5px 0 0;
  color: #1c3e5f;
  position: relative;
  cursor: pointer;
}

.indicator-status i.inactive {
  color: #b7b7b7 !important;
}

.indicator-status i.fa-shield-alt:after {
  content: "\f00d";
  position: absolute;
  right: 2px;
  top: 0px;
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 12px;
  color: #ac1260;
}

.indicator-status i.inactive.fa-shield-alt:after {
  content: "";
}

.indicator-status i.inactive.fa-shield-alt {
  color: #e91e63 !important
}

/*  */
.info-section {
  border: 1px solid #b8cad9;
