/**************************************************************************/
.section-modal h3 {
  background-image: -moz-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);
  background-image: -webkit-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);
  background-image: -ms-linear-gradient(90deg, rgb(28, 62, 95) 0%, rgb(37, 81, 123) 100%);
  margin: 0 0 5px 0;
  padding: 8px 10px;
  color: #fff;
  font-size: 13px;
}

/**************************************************************************************************/
.table > thead > tr > td,
.table > thead > tr > th {
  line-height: 12px;
  padding: 4px 3px;
  font-size: 10px;
  font-weight: 400;
}

/***************************************** accordion *******************************************/
.panel-heading [data-toggle="collapse"]:before {
  float: left !important;
  content: "\f068";
  margin-right: 6px;
  margin-top: 3px;
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 11px;
}

.panel-heading [data-toggle="collapse"].collapsed:before {
  float: left !important;
  content: "\f067";
}

.panel-heading [aria-expanded="true"].collapsed:before {
  content: "\f068" !important;
}

.panel-title > a:hover,
.panel-title > a:active,
.panel-title > a:focus {
  text-decoration: none;
}

.panel-group .panel {
  border-radius: 0;
  padding: 0;
  border: none;
  margin-bottom: 5px;
}

.panel-default > .panel-heading {
  color: #296dac;
  background-color: #d2e1ee;
  border-color: #ABBFD1;
  border-radius: 0;
  padding: 4px 0;
}

.panel-title {
  font-size: 13px;
  color: #297cc8;
  margin: 0;
}

.panel-title > a {
  display: block;
  padding: 4px 5px;
  text-decoration: none;
  color: #297cc8 !important;
}

.panel-default > .panel-heading + .panel-collapse > .panel-body {
  background-color: #FFF;
  border: 1px solid #d2e1ee;
  padding: 5px;
  margin: 5px auto;
}

.panel-body .table-nobg > thead > tr > th {
  border-bottom: 1px solid #c8c0c0 !important;
}

/* 5 col bootstrap */
.col-xs-5ths,
.col-sm-5ths,
.col-md-5ths,
.col-lg-5ths {
  position: relative;
  min-height: 1px;
  padding-right: 15px;
  padding-left: 15px;
}

.col-xs-5ths {
  width: 20%;
  float: left;
}

@media (min-width: 768px) {
  .col-sm-5ths {
    width: 20%;
    float: left;
  }
}

@media (min-width: 992px) {
  .col-md-5ths {
    width: 20%;
    float: left;
  }
}

@media (min-width: 1200px) {
  .col-lg-5ths {
    width: 20%;
    float: left;
  }
}

.priority-status {
  height: 6px;
  background: #fffcfc;
  border-radius: 0 0 3px 3px;
}

.high {
  background: #c23531;
}

.low {
  background: #0da551;
}

.normal {
  background: #f8c400;
}

/*  */
.text-red {
  color: red;
}

.text-green {
  color: green;
}

.block-section {
  border: 1px solid #d2e1ee;
  padding: 5px 15px 9px;
  margin: 4px 0 10px 0;
}

.filter-box {
  padding: 10px 15px;
  max-height: 400px;
  background: #fff;
  position: absolute;
  top: 0px;
  display: none;
  right: 0;
  text-align: left;
  border: 1px solid #abc5de;
  box-shadow: 0px 0px 6px rgba(72, 69, 69, 0.43);
  z-index: 999;
  left: 4px;
}

#groupBy.filter-box {
  right: 10px;
}

/* board */
.form-title {
  background: #d2e1ee;
  color: #297cc8 !important;
  padding: 6px 15px;
  font-size: 14px;
  margin-bottom: 3px;
  position: relative;
}

/*  */
.bread-crumb {
  margin: 0 0 5px;
}

.bread-list {
  text-align: center;
  background: #d2e1eeb0;
  padding: 0px 5px;
  color: #555;
  font-size: 11px;
  box-shadow: 0px 0px 1px #777;
  position: relative;
}

.bread-list a {
  color: #416b84;
}

.bread-list:after {
  content: "\f101";
  position: absolute;
  right: -19px;
  top: 2px;
  font-family: "Font Awesome 5 Free";
  font-weight: 900;
  font-size: 15px;
  color: #969595;
}

.bread-list i {
  font-size: 14px;
  /*! background: #416b8442; */
  border-radius: 9%;
  color: #416b84;
  height: 22px;
  width: 22px;
  padding: 4px 0;
  text-align: center;
}

.bread-list.select {
  background: #d7a342;
  color: #fff !important;
}

.bread-list.select i,
.bread-list.select a {
  color: #fff;
}

.bread-list.active {
  background: #296dac;
  color: #fff !important;
}

.bread-list.active i,
.bread-list.active a {
  color: #fff;
}

.priority-btn {
  width: 30px;
  height: 15px;
  display: inline-block;
  margin: 4px 2px 0;
  border-radius: 6px;
}

.priority-btn.high.unselect {
  background: #c2353178;
}

.priority-btn.low.unselect {
  background: #0da55178;
}

.priority-btn.normal.unselect {
  background: #f8c40078;
}

.add-task,
.add-Corrective {
  border: 1px solid #d2e1ee;
  padding: 5px 10px 10px;
  margin-top: 5px;
  background: #e0eaf3;
}

.addTask-btn,
.addCorrective-btn {
  font-size: 16px;
}

.addTask-btn.select,
.addCorrective-btn.select {
  color: #f8c400;
}

.filter-form-title-info {
  font-size: 13px;
  margin-left: 0;
  float: right;
}

.req-num,
.req-date {
  /*! color: #416b84; */
  /*! font-size: 12px; */
  padding: 0 1px;
}

.req-num {
  font-weight: 600;
}

/*  */
.bread-crumb .timeline-content p {
  line-height: 7px;
  padding-top: 10px;
  font-size: 11px;
  /*! font-weight: 600; */
  color: #1e548480;
  text-align: center;
}

.bread-crumb .timeline-content.active p,
.bread-crumb .timeline-content.select p {
  color: #1e5484;
}

.bread-crumb .timelineview {
  display: block;
  margin-top: 5px !important;
  position: relative;
  margin: auto;
}

.bread-crumb .timeline-box {
  text-align: center;
  margin-bottom: 0;
  z-index: 100;
  margin-top: 5px;
}

.bread-crumb .timeline-box a:hover {
  color: #fdae0e;
}

.bread-crumb .timeline-box::after {
  content: "";
  border-bottom: 2px #d2e1ee solid;
  position: absolute;
  width: 100%;
  top: 25px;
  margin-left: 0;
  z-index: 9;
}

.bread-crumb .timeline-box:last-child::before {
  content: "";
}

.bread-crumb .timeline-box:last-child::after {
  content: "";
  border-bottom: none;
}

.bread-crumb .timeline-box .icon-circle {
  position: relative;
  width: 45px;
  height: 45px;
  border-radius: 4px;
  background: #e0eaf3;
  text-align: center;
  padding: 3px 0;
  color: #3b3737;
  font-size: 27px;
  margin-left: auto;
  margin-right: auto;
  z-index: 100;
  line-height: 35px;
}

.bread-crumb .timeline-box .icon-circle a {
  position: relative;
  z-index: 2000;
}

@media (min-width: 1200px) {
  .bread-crumb .timeline-box:nth-child(6n+6)::after {
    border-bottom: none;
    content: "";
  }

  .bread-crumb .timeline-box:last-child::after {
    content: "";
    border-bottom: none;
  }
}

@media (min-width: 992px) and (max-width: 1199px) {
  .bread-crumb .timeline-box:nth-child(6n+6)::after {
    border-bottom: none;
    content: "";
  }

  .bread-crumb .timeline-box:last-child::after {
    content: "";
    border-bottom: none;
  }
}

@media (min-width: 768px) and (max-width: 991px) {
  .bread-crumb .timeline-box:nth-child(3n+3)::after {
    /*! border-bottom: none; */
    content: "";
  }

  .bread-crumb .timeline-box:last-child::after {
    content: "";
    border-bottom: none;
  }

  .no-padding-right {
    padding-right: 15px;
  }
}

@media (max-width: 767px) {
  .bread-crumb .timeline-box:nth-child(2n+2)::after {
    border-bottom: none;
    content: "";
  }

  .bread-crumb .timeline-box:last-child::after {
    content: "";
    border-bottom: none;
  }
}

.bread-crumb .timeline-box .icon-circle.select {
  color: #1e54ad;
  background: #d6e0e9;
}

.bread-crumb .timeline-box .icon-circle.select a {
  cursor: pointer;
}

.bread-crumb .timeline-box .icon-circle a {
  color: #1e548466;
  cursor: not-allowed;
}

.bread-crumb .timeline-box .icon-circle.icon-circle.select a {
  color: #1e5484 !important;
}

.bread-crumb .timeline-box .icon-circle.active::after {
  border: 2px solid #fdae0e;
}

.bread-crumb .timeline-box .icon-circle.active,
.bread-crumb .timeline-box .icon-circle:hover {
  background: #fdae0e;
  color: #fff;
}

.bread-crumb .timeline-box .icon-circle.active a {
  cursor: pointer;
}

.bread-crumb .timeline-box .icon-circle a {
  color: #fdfeffde;
  cursor: not-allowed;
}

.bread-crumb .timeline-box .icon-circle.icon-circle.active a {
  color: #fff !important;
}

.bread-crumb .timeline-box .icon-circle::after {
  content: '';
  border: 2px solid #d2e1ee;
  border-radius: 8px;
  width: 55px;
  height: 55px;
  position: absolute;
  left: -4.8px;
  top: 0px;
  bottom: 0;
  right: 0;
  margin: auto;
}

