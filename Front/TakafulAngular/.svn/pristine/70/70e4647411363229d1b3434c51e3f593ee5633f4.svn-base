  border-right: 1px solid #7fabc1;
}

.recur-sec label {
  margin: 0;
}

.align-item {
  align-items: center;
}

span .fa-times {
  color: #9a0000 !important;
}

.alert-custom {
  padding: 5px 10px;
}

.alert-custom i {
  font-size: 17px;
  top: 4px;
  margin-right: 4px;
}

.calc-item .select2-container {
  margin-bottom: 0px;
}

.calc-item .select2-container .select2-selection--single {
  height: 27px;
}

.calc-item .select2-container--default .select2-selection--single .select2-selection__rendered {
  line-height: 23px;
}

.f-grow div {
  flex-grow: 1;
}

.f-grow div:first-child {
  flex-grow: 1;
}

.f-grow div:last-child {
  flex-grow: 1;
}

.f-gap-10 {
  gap: 10px;
}

.calc-status {
  padding: 3px 5px;
  width: 50px;
  display: inline-block;
  border-radius: 3px;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

td .calc-status {
  width: 40px;
}

.calc-status.bg-present {
  color: #3c4858;
}

.legend-status {
  display: flex;
  flex-wrap: wrap; /*! justify-content: space-between; */
  gap: 6px;
  margin-bottom: 5px;
}

.legena-item {
  flex-grow: 6; /*! flex-direction: column; */
}

.legend-status .calc-status {
  margin-right: 5px;
}
