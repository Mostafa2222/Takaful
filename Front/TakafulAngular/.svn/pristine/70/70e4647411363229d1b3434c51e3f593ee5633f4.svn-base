.position-relative {
  position: relative;
}

/*.avatar-upload  */
.avatar-upload {
  position: relative;
  max-width: 100%;
  margin-bottom: 10px
}

.avatar-upload .avatar-edit {
  position: absolute;
  right: 3%;
  z-index: 1;
  top: 3% /*! background: #888; */
}

.avatar-upload .avatar-edit input {
  display: none
}

.avatar-upload .avatar-edit input + label {
  display: inline-block;
  width: 34px;
  height: 34px;
  margin-bottom: 0;
  border-radius: 100%;
  background: #fbfDFF54;
  border: 1px solid #cac8c8eb;
  box-shadow: 0 2px 4px 0 rgba(0, 0, 0, .12);
  cursor: pointer;
  font-weight: 400;
  transition: all .2s ease-in-out /*! font-size: 16px; */
}

.avatar-upload .avatar-edit input + label:hover {
  background: #f1f1f1;
  border-color: #d6d6d6
}

.avatar-upload .avatar-edit input + label:after {
  content: "\f03e";
  font-family: 'Font Awesome 5 Free';
  color: #76797b;
  position: absolute;
  top: 7px;
  left: 0;
  right: 0;
  text-align: center;
  margin: auto;
  font-size: 15px
}

.avatar-upload .avatar-preview {
  width: 100%;
  height: 160px;
  position: relative;
  box-shadow: 0 2px 4px 0 rgba(0, 0, 0, .1);
  border: 1px solid #eae4e4;
  padding: 5px
}

.avatar-upload .avatar-preview > div {
  width: 100%;
  height: 100%;
  border-radius: 0;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center
}

table .avatar-upload {
  margin-bottom: 0
}

table .avatar-upload .avatar-preview {
  height: 40px;
  padding: 1px;
  width: 50px;
  margin: auto
}

table .avatar-upload .avatar-edit input + label::after {
  top: 4px !important
}

table .avatar-upload .avatar-edit input + label {
  width: 20px;
  height: 20px;
  border: 1px solid #ffffffeb;
  box-shadow: none
}

table .avatar-upload .avatar-edit input + label:hover {
  background: #fff;
  border-color: #fff
}

table .avatar-upload .avatar-edit {
  right: 23%;
  top: -2%
}

#tbProLine .selected {
  background-color: #666;
  color: #fff
}

/*  */
/* .table-hover > tbody > tr:hover, .table-striped > tbody > tr:nth-of-type(2n) {background-color: initial; } */
.child-table .form-group {
  margin-bottom: 3px
}

.child-table h2 {
  font-size: 13px !important
}

/*  */
.ref-btn a {
  text-decoration: underline !important;
  color: #5470c6
}

.sort-item {
  padding: 3px 6px;
  margin-right: 7px;
  border-radius: 3px;
  background: #fff;
  border: 1px solid #c0c0c1;
  color: #737374 !important;
  font-size: 11px
}

.sort-item i {
  font-size: 14px
}

.sort-item.active {
  background: #2c7dbd;
  color: #fff !important;
  border-color: #2c7dbd
}

.second-title h2 {
  margin: 10px 5px;
  font-weight: 600 /*! display: inline-block; */
}

.second-title .action {
  display: inline-flex;
  margin-left: 55px /*! width: 150px; */
}

.modal-title {
  font-weight: 600
}

/*  7th col */
@media (min-width: 768px) {
  .seven-cols .col-lg-1, .seven-cols .col-md-1, .seven-cols .col-sm-1 {
    width: 100%
  }
}

@media (min-width: 992px) {
  .seven-cols .col-lg-1, .seven-cols .col-md-1, .seven-cols .col-sm-1 {
    width: 14.285714285714285714285714285714%
  }
}

@media (min-width: 1200px) {
  .seven-cols .col-lg-1, .seven-cols .col-md-1, .seven-cols .col-sm-1 {
    width: 14.285714285714285714285714285714%
  }
}

/*  */
.form-control[disabled], .form-control[readonly], fieldset[disabled] .form-control {
  background-color: #e9e8e8
}

.ml-45p {
  margin-left: 45%;
}

/*  */
.table thead, .table tfoot {
  text-transform: initial;
}

/***************   ***************/
table tr:first-of-type .create-row {
  display: inline-block;
}

.verticalTableHeader {
  background: #26537e;
  background: -webkit-gradient(linear, left top, left bottom, from(#26537e), to(#1a3a59));
  background: linear-gradient(to bottom, #26537e 0, #1a3a59 100%);
  width: 20px;
  height: 100px
}

.verticalTableHeader span {
  transform: rotate(270deg);
  color: #fff;
  padding-bottom: 10px;
  top: 50%;
  left: 1px;
  position: absolute
}

th.action, td.action {
  width: 50px;
}

/*   */
.SelectionSelect {
  margin-bottom: 10px;
}

/***************************************** new row *******************************************/
.calearMeetingDate, .discSelect, .discount, .newrow1, .newrow2 {
  display: none
}

.calearMeetingDate.active {
  display: block
}

/***************************************** fieldset *******************************************/
.dicRadio label {
  color: #333
}

/***************************************** form *******************************************/
.entry:not(:first-of-type) {
  margin-top: 0
}

.controls .input-group {
  display: table;
  border: 1px solid #d8d1d1;
  padding: 0;
  margin: 0 2px 5px;
  float: left
}

.controls .input-group input {
  border: none;
  font-size: 11px;
  margin: 2px 0 0;
  border-radius: 0;
  width: 100%;
  text-align: inherit
}

/***************************************** Popup *******************************************/
.itemBtn {
  text-decoration: underline
}

.table-overlay {
  padding: 2px 1px;
  min-width: 350px;
  margin: auto;
  position: fixed;
  width: auto
}

.GroupItem_popup .table-overlay {
  padding: 2px 1px;
  min-width: 200px;
  margin: auto;
  position: fixed;
  width: auto
}

.table-overlay .popover-content {
  padding: 0 1px
}

.short-full {
  float: right;
  color: #fff
}

/* -------------------------------------  ------------------------------------- */
.searchableTh i.fa-search { /*! cursor:pointer; *//*! font-size:11px; *//*! padding-left:3px; *//*! float:right; */
  padding: 0 7px;
}

/*  */
.has-sub .third-sub .sub-third .s-sub::before {
  top: 5px
}

.has-sub .third-sub .sub-third .s-sub.opened::before {
  top: 2px
}

.third-sub .sub-third ul.sub li > a {
  text-indent: 20px
}

/*  */
.vertical-tabs .nav-pills .nav-link.active, .vertical-tabs .nav-pills .show > .nav-link {
  color: #2c6aa5;
  background-color: #d2e1ee
}

.vertical-tabs .nav-link {
  padding: .3rem .5rem;
  color: #4c4c4c;
  text-align: left;
  border-radius: 3px;
  margin-bottom: 8px
}

.vertical-tabs .number-box {
  padding: 3px 5px;
  background: #1e4366;
  font-size: 11px
}

.vertical-tabs h3 {
  background: #d2e1ee;
  padding: 5px 15px;
  text-align: center;
  border-radius: 3px
}

textarea.form-control {
  height: auto
}

.square-icon.select {
  color: #f8c400 !important;
}

.square-icon i {
  font-size: 15px
}

.square-icon i.fa-plus {
  font-size: 10px
}

.square-icon.select i.fa-plus {
  color: #fff !important;
  background: #f8c400 !important;
  font-size: 10px
}

.row-inline-editable.active .based-Frequency input {
  width: auto !important;
  margin-right: 3px
}

/*  */
.status-box {
  border-radius: 3px;
  padding: 2px 15px; /*! max-width: 150px; */
  margin: auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-box i {
  margin-right: 5px;
}

.status-box.time-static, .time-static {
