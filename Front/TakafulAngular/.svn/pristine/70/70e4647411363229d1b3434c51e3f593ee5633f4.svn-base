/*  */
.tabs-left,
.tabs-right {
  border-bottom: none;
  padding-top: 0;
}

.tabs-right {
  border-left: none;
}

.tabs-left > li,
.tabs-right > li {
  float: none;
}

.tabs-left > li {
  margin-right: -1px;
  line-height: 11px;
}

.tabs-right > li {
  margin-left: -1px;
}

.tabs-left > li.active > a:focus,
.tabs-left > li > a:hover {
  background-color: #d2e1ee;
  /*! color: #fff; */
  border: none;
}

.tabs-left > li > a {
  border-radius: 0;
  padding: 4px 8px;
  font-size: 13px;
  margin: 0 0 5px 0;
  border: none;
  color: #333;
}

.tabs-left > li.active > a,
.tabs-left > li.active > a:hover {
  background-color: #d2e1ee;
  border-radius: 3px;
  border: none;
  color: #2c6aa5;
}

.tabs-right > li > a {
  margin-right: 0;
}

.tab-content.verticalTabs {
  /*! min-height: 400px; */
  overflow-y: auto;
  padding: 1px 15px 5px;
}

.tab-content.verticalTabs > .tab-pane {
  display: none;
}

.tab-content.verticalTabs > .active {
  display: block;
}

.high,
.low {
  color: #fff;
}

