.tooltip-inner {
  color: unset;
  background: unset;
}

.popper,
.tooltip {
  position: absolute;
  z-index: 9999;
  background: #f1f7fd;
  color: black;
  width: 200px;
  border-radius: 3px;
  box-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
  padding: 0px;
  text-align: center;
  opacity: 1;
}

.style5 .tooltip {
  background: #1E252B;
  color: #FFFFFF;
  max-width: 200px;
  width: auto;
  font-size: .8rem;
  padding: 0px;
}

.popper .popper__arrow,
.tooltip .tooltip-arrow {
  width: 0;
  height: 0;
  border-style: solid;
  position: absolute;
  margin: 0px;
}

.tooltip .tooltip-arrow,
.popper .popper__arrow,
.style5 .tooltip .tooltip-arrow {
  border: none;
}

.tooltip,
.actions .tooltip,
table .tooltip,
.block-section .tooltip,
fieldset .tooltip,
.assets-defin .tooltip {
  background: #1e4367;
  color: #f7f7f7;
  width: auto;
  border-radius: 3px;
  box-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
  padding: 0px;
}

.tooltip,
.actions .tooltip .tooltip-arrow,
table .tooltip .tooltip-arrow,
.block-section .tooltip .tooltip-arrow,
fieldset .tooltip .tooltip-arrow,
.assets-defin .tooltip .tooltip-arrow {
  border: none;
}

