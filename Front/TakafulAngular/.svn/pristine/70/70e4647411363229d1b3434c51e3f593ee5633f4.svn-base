}

.report-item h3 {
  font-size: 13px;
  color: #21496f;
  font-weight: 600;
  margin: 10px 0 8px;
}

.report-item .table > thead > tr > td,
.report-item .table > thead > tr > th {
  font-size: 12px;
  font-weight: 600;
}

.report-item .table > tbody > tr > td {
  border-top: 1px solid #ddd0;
  padding: 5px 8px;
}

.date {
  color: #1f4569;
  min-height: 40px;
  line-height: 30px;
  font-size: 11px;
  font-weight: 600;
}

.pages {
  font-size: 10px;
  font-weight: 600;
  color: #1f4569;
  line-height: 28px;
}

.report .actions a {
  line-height: 30px;
  height: 30px;
  width: 30px;
}

.report .actions a:hover {
  background: unset;
}

.report .footer {
  background: #fff;
  text-align: center;
  border-top: 1px solid #9b9b9b;
  margin-top: 10px;
  padding: 4px 15px;
  /*! position: fixed; */
  bottom: 0;
  /*! width: 98%; */
}

.table-nobg > tfoot > tr > td,
.table-nobg > tfoot > tr > th,
.table-nobg > thead > tr > td,
.table-nobg > thead > tr > th {
  font-size: 11px;
  font-weight: 600;
  line-height: 10px;
  padding: 6px 3px;
}

.table-nobg > thead,
.table-nobg > tfoot {
  background: #fff !important;
  color: #1d4163;
  text-transform: capitalize;
}

.table-nobg > thead > tr > th {
  border-bottom: 1px solid #6b6b6b !important;
}

.table-nobg > tfoot > tr > th {
  border-top: 1px solid #6b6b6b !important;
  padding: 5px 8px;
}

.table-nobg > tr {
  border-bottom: 1px solid #bbd2e6;
  white-space: nowrap;
}

.table-nobg > tbody > tr:nth-of-type(even),
.table-nobg > tbody > tr:nth-of-type(odd) {
  background: none;
}

.table-nobg > tbody > tr > td {
  line-height: 12px;
  padding: 5px 8px;
  text-align: initial;
}

.printBtn {
