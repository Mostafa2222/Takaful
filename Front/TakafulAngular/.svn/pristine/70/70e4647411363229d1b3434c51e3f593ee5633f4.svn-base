.bold {
  font-weight: bold !important;
}

/*-----------------------------------------------------  */
a {
  text-decoration: none !important
}

a.inactive {
  cursor: not-allowed;
  color: #b7b7b7
}

.dataTables_length {
  bottom: 33px
}

.cu-table select, .dataTables_length select {
  color: #777;
  height: 18px !important
}

.dataTables_wrapper {
  position: relative
}

.pageTitle {
  z-index: 999
}

input[type=date].form-control, input[type=datetime-local].form-control, input[type=month].form-control, input[type=time].form-control {
  line-height: 20px
}

.modal-header {
  border-bottom: none;
  background: #ececec;
}

 

.table {
  width: 100% !important
}

.btn.btn-primary.addBtn {
  background: #0463bf !important;
  line-height: 15px !important;
  height: 17px;
  width: 17px;
  font-size: 11px
}

img {
  max-width: 100%
}

.dnone {
  display: none !important;
}

/************************************ **********/
.section-modal h3 {
  background-image: -moz-linear-gradient(90deg, #1c3e5f 0, #25517b 100%);
  background-image: -webkit-linear-gradient(90deg, #1c3e5f 0, #25517b 100%);
  background-image: -ms-linear-gradient(90deg, #1c3e5f 0, #25517b 100%);
  margin: 0 0 5px 0;
  padding: 8px 10px;
  color: #fff;
  font-size: 13px
}

/**************************************************************************************************/
.table > thead > tr > td, .table > thead > tr > th {
  line-height: 12px;
  padding: 5px 3px;
  font-size: 10px;
  font-weight: 400
}

/*************************************************** Inline Editing ****************************************/
.row-inline-editable .avatar-upload, .row-inline-editable .chosen-container, .row-inline-editable input, .row-inline-editable select {
  display: none
}

.row-inline-editable.active input, .row-inline-editable.active label, .row-inline-editable.active select {
  display: inline
}

.row-inline-editable input[type=radio] {
  display: inline-block
}

.row-inline-editable.active .chosen-container {
  display: inline-block
}

.row-inline-editable.active .chosen-container span {
  display: inline;
}

.row-inline-editable.active span {
  display: none
}

.row-inline-editable.active {
  background-color: inherit !important
}

.row-inline-editable span.editable {
  display: inline
}

.row-inline-editable.active .avatar-upload, .row-inline-editable.active span {
  display: block
}

.editable.label {
  font-weight: 500;
  font-size: inherit
}

.row-inline-editable span, .row-inline-editable.active span.editable {
  display: none
}

.row-inline-editable span, .row-inline-editable.active br, .row-inline-editable.active span.editable {
  display: none;
}

.fa-check-double.active, .fa-check, .fa-check-double.active, .fa-check {
  color: green;
}

.fa-times, .fa-times {
  color: #c0d5e8;
}

/*************************************************** Inline Adding ****************************************/
/* .new-row,.new-row .glyphicon-trash,.new-row.active .glyphicon-plus-sign {display: inline-block;} */
.new-row, .new-row .glyphicon-trash, .new-row.active .glyphicon-plus-sign {
  display: none
}

.row-inline-adding {
  display: none
}

.main .row-inline-adding {
  display: inline
}

.new-row.active {
  display: table-row
}

.table > tbody > tr.new-row.active > td {
  background-color: inherit !important
}

.radio-inline input[type=radio] {
  margin-top: -2px
}

/************ Select2 *************/
table .select2-container {
  margin-bottom: 0;
}

.select2-container {
  margin-bottom: 7px;
}

.select2-container--default .select2-selection--single .select2-selection__rendered {
  line-height: 16px;
  font-size: 12px;
}

.select2-container--default .select2-selection--single .select2-selection__rendered i {
  font-size: 17px;
  margin-right: 3px;
}

.select2-container--default .select2-selection--single .select2-selection__arrow {
  height: 22px;
}

.select2-container .select2-selection--multiple {
  height: 20px;
  line-height: 20px;
  min-height: 20px;
  padding: 1px 0;
}

.select2-container--default .select2-selection--single {
  background-color: #fff;
  border: 1px solid #ccc;
  border-radius: 0;
}

.select2-container .select2-selection--single {
  box-sizing: border-box;
  cursor: pointer;
  display: block;
  height: 20px;
  user-select: none;
  -webkit-user-select: none;
}

.select2-container--default .select2-selection--multiple .select2-selection__choice {
  background-color: #f5f4f4;
  border: 1px solid #aaaaaa45;
  border-radius: 0;
  margin-right: 4px;
  margin-top: 0;
  padding: 0 2px;
  font-size: 11px;
  line-height: 15px;
}

.select2-container--default.select2-container--focus .select2-selection--multiple {
  border: solid #ccc 1px;
}

.select2-container--default .select2-selection--multiple {
  border: 1px solid #aaa;
  border-radius: 1px;
}

/* *********************************************************************************************** */
tr.shown .details-control .fa-plus::before {
  content: "\f068";
}

.tableChild.pre-scrollable {
  max-height: 250px;
}

/******************************************************Backgrounds*************************************/
.i-active i {
  color: #337ab7 !important;
}

/**********************************************************************************************************/
.col-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 0;
}

.borderBottom {
  border-bottom: 2px solid #c3c2c2;
}

.lightBg {
  background: unset;
}

/* ******************************************** datatable ****************************************** */
tbody tr.selected,
table.dataTable tbody tr.selected {
  background-color: #B0BED9;
  color: #333;
}

/* thead tr .selected th,
table.dataTable thead tr.selected {
    background-color: unset;
    color: unset;
} */

a.btn {
  color: #fff !important;
}

table.dataTable tbody tr.selected a,
table.dataTable tbody th.selected a,
table.dataTable tbody td.selected a {
  color: #337ab7;
}

/* ------------------------------------- upload file----------------------------------- */
