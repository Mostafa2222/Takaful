}

/* report page */
.report {
  font-size: 12px;
  overflow: auto;
}

.report header {
  position: relative;
  /*! width: 100%; */
}

.report .content {
  padding-bottom: 25px;
  position: unset;
  padding-top: 15px;
  /*! height: calc(100% - 70px - 50px); */
  background: transparent;
}

.report-title {
  margin: 0 0 5px;
  text-align: center;
  font-size: 18px !important;
  color: #20476d;
}

.report-box {
  margin: 0 0 1px;
  padding: 5px 20px;
  border: 1px solid #979292;
  /*! border-radius: 5px; */
}

.report-box h4 {
  font-size: 13px;
  font-weight: 600;
  margin: 0;
}

.report-box-content {
  padding: 10px 10px 15px;
}

.rep-items {
  margin-bottom: 10px;
}

.rep-items label {
  margin-bottom: 3px;
  color: initial;
  font-weight: 600;
  font-size: 10px;
}

.img-table-small {
  height: 55px;
  border: 1px solid #cfcbcb;
}

.report .equip-img {
  border: 1px solid #b3b0b0;
  padding: 2px;
  text-align: center;
  margin-top: 7px;
}

.report .equip-img img {
  max-height: 100px;
}

.report .barcode-img {
  text-align: center;
  border-top: none;
  padding: 1px 5px 1px;
  /*! background: #ebebeb; */
  margin: 0;
}

.report .barcode-img img {
