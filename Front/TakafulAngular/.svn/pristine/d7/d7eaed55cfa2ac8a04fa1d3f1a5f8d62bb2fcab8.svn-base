<!-- address setup Modal -->
<div class="modal fade" id="addressModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl">
      <div class="modal-content">
          <div class="modal-header">
              <h1 class="modal-title fs-5">{{"Organization.Timeline.Legal_Status.Address.Address_Setup" | translate}}
              </h1>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
              <div class="table-responsive">
                  <table class="table table-striped table-hover table-sm">
                      <colgroup>
                          <col>
                          <col>
                          <col>
                          <col>
                          <col>
                          <col>
                          <col>
                          <col>
                          <col>
                      </colgroup>
                      <thead>
                          <tr>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Level"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.English_Name"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Arabic_Name"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Segment_Width"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Transactional"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Organizational_Chart"| translate}}
                              </th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Purchasing"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Inventory"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Edit"| translate}}</th>
                              <th>{{"Organization.Timeline.Legal_Status.Address.Delete"| translate}}</th>
                          </tr>
                      </thead>
                      <tbody>
                          <tr *ngFor="let level of levelsDescriptions; let i = index">
                              <td class="text-center">{{ level.levelId }}</td>

                              <td>
                                  <input *ngIf="selectedLevelId === level.levelId" [(ngModel)]="level.englishName"
                                      class="form-control" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.englishName }}</span>
                              </td>
                              <td>
                                  <input *ngIf="selectedLevelId === level.levelId" [(ngModel)]="level.arabicName"
                                      class="form-control" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.arabicName }}</span>
                              </td>
                              <td class="text-center">
                                  <input *ngIf="selectedLevelId === level.levelId" type="number"
                                      [(ngModel)]="level.segmentWidth"  style="width: 5rem;" class="form-control text-center" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.segmentWidth }}</span>
                              </td>
                              <td class="text-center">
                                  <input *ngIf="selectedLevelId === level.levelId" type="checkbox"
                                      [(ngModel)]="level.transactionalBool" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.transactional }}</span>
                              </td>
                              <td class="text-center">
                                  <input *ngIf="selectedLevelId === level.levelId" type="checkbox"
                                      [(ngModel)]="level.organizationChartBool" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.organizationChart }}</span>
                              </td>
                              <td class="text-center">
                                  <input *ngIf="selectedLevelId === level.levelId" type="checkbox"
                                      [(ngModel)]="level.purchasingBool" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.purchasing }}</span>
                              </td>
                              <td class="text-center">
                                  <input *ngIf="selectedLevelId === level.levelId" type="checkbox"
                                      [(ngModel)]="level.inventoryBool" />
                                  <span *ngIf="selectedLevelId !== level.levelId">{{ level.inventory }}</span>
                              </td>
                              <!-- <td class="text-center">
                      <button *ngIf="selectedLevelId !== level.levelId" class="btn btn-primary btn-sm" [disabled]="i < 5"  (click)="editRow(level.levelId)">Edit</button>
                      <button *ngIf="selectedLevelId === level.levelId" class="btn btn-success btn-sm" (click)="saveEditedRow(level)">Save</button>
                      <button *ngIf="selectedLevelId === level.levelId" class="btn btn-secondary btn-sm" (click)="cancelEdit()">Cancel</button>

                    </td>
                    <td class="text-center"><button class="text-danger delete-row fa fa-trash-alt" [disabled]="i < 5" (click)="deleteRow(level.levelId)">Delete</button></td> -->

                              <td class="text-center">
                                  <button style="border: none;background:none;" [disabled]="i < maxLevelId"
                                      *ngIf="selectedLevelId !== level.levelId"
                                      [ngClass]="{'text-primary' : i >= maxLevelId }"
                                      class=" row-edit fa fa-pencil-alt" (click)="editRow(level.levelId)"></button>
                                  <button *ngIf="selectedLevelId === level.levelId"
                                    class="btn btn-success btn-sm"
                                      (click)="saveEditedRow(level)">
                                      <i class="fa-solid fa-check text-light"></i>
                                    </button>
                                  <button *ngIf="selectedLevelId === level.levelId"
                                  class="btn btn-danger btn-sm"
                                      (click)="cancelEdit()">
                                      <i class="fa-solid fa-xmark text-light"></i></button>
                              </td>
                              <td class="text-center"><button style="border: none;background:none;"
                                      [disabled]="i < maxLevelId" [ngClass]="{'text-danger' : i >= maxLevelId }"
                                      class=" delete-row fa fa-trash-alt" (click)="deleteRow(level.levelId)"></button>
                              </td>
                          </tr>

                          <!-- New Row (For Adding New Entry) -->
                          <tr>
                              <td class="text-center">{{"Organization.Timeline.Legal_Status.Address.New"| translate}}
                              </td>
                              <td>
                                <input
                                  type="text"
                                  [(ngModel)]="newLevel.englishName"
                                  class="form-control"
                                  placeholder="{{'Organization.Timeline.Legal_Status.Address.English_Name' | translate}}"
                                  (input)="newLevel.englishName = newLevel.englishName.trimStart()"
                                />
                              </td>

                              <td>
                                <input
                                  type="text"
                                  [(ngModel)]="newLevel.arabicName"
                                  class="form-control"
                                  placeholder="{{'Organization.Timeline.Legal_Status.Address.Arabic_Name' | translate}}"
                                  (input)="newLevel.arabicName = newLevel.arabicName.trimStart()"
                                />
                              </td>

                              <td class=""><input type="number" min="0" [(ngModel)]="newLevel.segmentWidth"
                                      class="form-control text-center" style="max-width: 5rem;"
                                      placeholder="{{'Organization.Timeline.Legal_Status.Address.Segment_Width'| translate}}" />
                              </td>
                              <td class="text-center"><input type="checkbox"
                                      [(ngModel)]="newLevel.transactionalBool" /></td>
                              <td class="text-center"><input type="checkbox"
                                      [(ngModel)]="newLevel.organizationChartBool" /></td>
                              <td class="text-center"><input type="checkbox" [(ngModel)]="newLevel.purchasingBool" />
                              </td>
                              <td class="text-center"><input type="checkbox" [(ngModel)]="newLevel.inventoryBool" />
                              </td>
                              <td class="text-center"><a href="#" (click)="addRow()" class="btn btn-primary">
                                <i class="fa fa-floppy-disk"></i>
                                  </a></td>
                          </tr>

                      </tbody>
                  </table>
              </div>

          </div>
          <!-- <div class="modal-footer">
            <button type="button" class="btn btn-danger" data-bs-dismiss="modal">{{"Organization.Timeline.Legal_Status.Address.Close"| translate}}</button>
            <button type="button" (click)="saveAllLevels()" class="btn btn-primary" data-bs-dismiss="modal">{{"Organization.Timeline.Legal_Status.Address.Save"| translate}}</button>
            <button type="button" (click)="submitToBackend()" class="btn btn-success" data-bs-dismiss="modal">{{"Organization.Timeline.Legal_Status.Address.Submit"| translate}}</button>
          </div> -->
      </div>
  </div>
</div>
