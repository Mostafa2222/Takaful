<app-loading *ngIf="isLoading">{{ isLoading }}</app-loading>
<div class="container-fluid DMSBlueBlue bg-img">
  <!-- content -->
  <div class="">
    <div class="page-content p-0">
      <div class="login-sec vh-100">
        <div class="col-12 col-md-5 login-details">
          <div class="dms-logo">
            <img src="assets/images/dms-black-logo.png" alt="DMS" />
          </div>
        </div>
        <div class="col-12 col-md-7 login-form">
          <div class="client-logo">
            <img src="assets/images/client-logo.png" alt="" />
          </div>
          <form [formGroup]="userLoginForm" (ngSubmit)="login()">
            <div class="input-group mb-3">
              <span class="input-group-text"><i class="fas fa-user"></i></span>
              <input
                type="text"
                class="form-control login-input"
                placeholder="Username"
                name="username"
                formControlName="username"
              />
            </div>
            <div class="input-group mb-3">
              <span class="input-group-text"><i class="fas fa-key"></i></span>
              <input
                type="password"
                class="login-input form-control changeTextToPassword"
                placeholder="password"
                formControlName="password"
              />
            </div>
            <div class="input-group mb-3">
              <span class="input-group-text"
                ><i class="fas fa-building"></i
              ></span>
              <select
                id="branchId"
                class="form-select"
                style="padding-top: 1px; font-weight: 500;"
                formControlName="branch"
              >
                <!-- Render standalone/group options if isStandAlone is false -->
                <ng-container *ngIf="isStandAlone; else branchOptions">
                  <option value="" style="font-weight: 500;">Select Option</option>
                  <option value="standalone" text="standalone" style="font-weight: 500;">
                    Standalone
                  </option>
                  <option value="Group" text="Group" style="font-weight: 500;">Group</option>
                </ng-container>

                <!-- Template for branch options -->
                <ng-template #branchOptions>
                  <option value="" style="font-weight: 500;">Select Branch</option>
                  <option
                    *ngFor="let userBranch of authorizedBranches"
                    [value]="userBranch.defintionId"
                    [text]="userBranch.arabicName"
                    [label]="userBranch.englishName"
                    style="font-weight: 500;"
                  >

                  </option>
                </ng-template>
              </select>
            </div>

            <div class="app-login">
              <!--<a href="#"><img src="assets/images/MenuPortal.png" alt=""></a>
                      <a href="#"><img src="assets/images/DoctorPortal.png" alt=""></a>
                      <a href="#"><img src="assets/images/MISPortal.png" alt=""></a>
                      <a href="#"><img src="assets/images/NursePortal.png" alt=""></a>
                       -->
            </div>
            <div class="text-end">
              <button type="submit" class="btn btn-primary">Login</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<app-footer></app-footer>
