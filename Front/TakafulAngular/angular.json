{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "TakafulProject": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "standalone": false
        },
        "@schematics/angular:directive": {
          "standalone": false
        },
        "@schematics/angular:pipe": {
          "standalone": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/takaful",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "node_modules/leaflet/dist/leaflet.css",
              "src/styles.css",
              "@angular/material/prebuilt-themes/azure-blue.css",
              "node_modules/leaflet/dist/leaflet.css",
              "public/assets/css/datatables.min.css",
              "public/assets/css/dataTables.bootstrap5.min.css",
              "public/assets/fonts/font-awesome/css/all.css",
              "public/assets/css/jquery-ui.min.css",
              "public/assets/css/jquery.datetimepicker.min.css",
              "public/assets/css/select2.min.css",
              "public/assets/css/DmsFont.css",
              "public/assets/css/DmsNewFont.css",
              "public/assets/css/en-font.css",
              "public/assets/fonts/medilight-font/style.css",
              "public/assets/js/jqwidgets/styles/jqx.base.css",
              "public/assets/js/jqwidgets/styles/jqx.bootstrap.css",
              "public/assets/css/org.css",
              "node_modules/ngx-toastr/toastr.css",
              "node_modules/primeng/resources/themes/lara-light-indigo/theme.css",
              "node_modules/primeng/resources/primeng.min.css",
              "node_modules/primeicons/primeicons.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.min.js",
              "public/assets/js/jquery-3.6.1.min.js" ,
              "public/assets/js/jquery-ui.min.js" ,
              "public/assets/js/bootstrap.bundle.min.js" ,
              "public/assets/js/dataTables.min.js" ,
              "public/assets/js/dataTables.bootstrap5.min.js" ,
              "public/assets/js/fixedColumns.dataTables.min.js" ,
              "public/assets/js/dataTables.buttons.min.js" ,
              "public/assets/js/buttons.colVis.min.js" ,
              "public/assets/js/buttons.html5.min.js" ,
              "public/assets/js/buttons.print.min.js" ,
              "public/assets/js/pdfmake.min.js" ,
              "public/assets/js/select.dataTables.min.js" ,
              "public/assets/js/echarts.min.js" ,
              "public/assets/js/echarts-theme-shine.js" ,
              "public/assets/js/jquery.datetimepicker.full.min.js" ,
              "public/assets/js/select2.min.js" ,
              "public/assets/js/jquery.nicescroll.min.js" ,
              "public/assets/js/DMSmain.js" ,
              "public/assets/js/org.js" ,
              "public/assets/js/jqwidgets/jqxcore.js" ,
              "public/assets/js/jqwidgets/jqxbuttons.js" ,
              "public/assets/js/jqwidgets/jqxscrollbar.js" ,
              "public/assets/js/jqwidgets/jqxpanel.js" ,
              "public/assets/js/jqwidgets/jqxcheckbox.js"
          ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "6MB",
                  "maximumError": "8MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "100kB",
                  "maximumError": "500kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "TakafulProject:build:production"
            },
            "development": {
              "buildTarget": "TakafulProject:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public/assets"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
